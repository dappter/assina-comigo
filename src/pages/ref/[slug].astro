                        "inverse-surface": "#313033",
                        "on-background": "#1C1B1E",
                        "on-error": "#FFFFFF",
                        "on-error-container": "#410002",
                        "on-primary": "#FFFFFF",
                        "on-primary-container": "#1E0061",
                        "on-primary-fixed": "#1E0061",
