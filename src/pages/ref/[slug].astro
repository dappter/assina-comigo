---
import raioLogo from "../../assets/icons/RAIO.png";
import faviconIco from "../../assets/icons/favicon.ico";
import favicon16 from "../../assets/icons/favicon-16x16.png";
import favicon32 from "../../assets/icons/favicon-32x32.png";
import appleTouchIcon from "../../assets/icons/apple-touch-icon.png";
import logoLigeiraHorizontal from "../../assets/branding/LOGO LIGEIRA HORIZONTAL COM ADESIVO 2026.png";
import ligiaHeroImage from "../../assets/branding/LIGIA LP ASSINA COMIGO.png";
import { partnerService } from "../../services/partnerService";
import { indicationService } from "../../services/indicationService";
import { sanitizePhone, isValidWhatsApp } from "../../utils/validation";

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect("/404");
}

const partner = await partnerService.getPartnerBySlug(slug);

if (!partner) {
    return Astro.redirect("/404?error=partner_not_found");
}

const partnerName = partner.nome;

let success = false;
let errorMsg = "";

if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData();
        const nome = data.get("nome") as string;
        const telefone = data.get("whatsapp") as string;
        const cpf = data.get("cpf") as string;
        
        // Novos campos de endereço
        const cep = data.get("cep") as string;
        const logradouro = data.get("logradouro") as string;
        const numero = data.get("numero") as string;
        const bairro = data.get("bairro") as string;
        const cidade = data.get("cidade") as string;
        const complemento = data.get("complemento") as string;

        if (nome && telefone && cidade) {
            const cleanWhatsapp = sanitizePhone(telefone);

            if (!isValidWhatsApp(cleanWhatsapp)) {
                errorMsg = "Informe um WhatsApp brasileiro valido com DDD e 11 digitos.";
            } else {
                // Montar endereço formatado para o campo 'local' ou append no nome
                const enderecoCompleto = `${logradouro}, ${numero}${complemento ? ' - ' + complemento : ''}, ${bairro}, ${cidade} - CEP: ${cep}`;
                const leadNome = `${nome} (${enderecoCompleto})`;

                await indicationService.createIndication(
                    partner.tenant_id,
                    {
                        parceiro_id: partner.id,
                        nome: leadNome,
                        telefone: cleanWhatsapp,
                        cpf: cpf || "",
                        status: "Recebido",
                    },
                );

                success = true;
            }
        } else {
            errorMsg = "Nome, WhatsApp e Endereço completo são obrigatórios.";
        }
    } catch (error: any) {
        errorMsg = error?.message || "Ocorreu um erro ao enviar sua requisição. Tente novamente.";
        console.error("[Backend Log] Erro ao salvar lead:", error);
    }
}
---

<!DOCTYPE html>
<html class="scroll-smooth" lang="pt-BR">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <link rel="icon" type="image/x-icon" href={faviconIco.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16.src} />
    
    <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined" rel="stylesheet">
    
    <script is:inline>
