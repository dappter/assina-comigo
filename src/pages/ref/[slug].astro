---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/ui/Button.astro";
import {
    User,
    Smartphone,
    MapPin,
    CreditCard,
    Send,
    Sparkles,
} from "@lucide/astro";
import { partnerService } from "../../services/partnerService";
import { indicationService } from "../../services/indicationService";

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect("/404");
}

const partner = await partnerService.getPartnerByIdGlobal(slug);

if (!partner) {
    // Parceiro não existe
    return Astro.redirect("/404?error=partner_not_found");
}

const partnerName = partner.nome;

let success = false;
let errorMsg = "";

if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData();
        const nome = data.get("nome") as string;
        const telefone = data.get("whatsapp") as string;
        const cpf = data.get("cpf") as string;
        const local = data.get("local") as string;

        console.log(
            `[Backend Log] Tentativa de criação de indicação - Parceiro: ${partner.nome} (ID: ${partner.id}), Tenant: ${partner.tenant_id}`,
        );
        console.log(
            `[Backend Log] Dados recebidos -> Nome: ${nome}, Tel: ${telefone}, CPF: ${cpf}, Local: ${local}`,
        );

        if (nome && telefone) {
            const leadNome = local ? `${nome} (${local})` : nome;

            const lead = await indicationService.createIndication(
                partner.tenant_id,
                {
                    parceiro_id: partner.id,
                    nome: leadNome,
                    telefone,
                    cpf: cpf || "",
                    status: "PENDENTE",
                },
            );

            console.log(
                `[Backend Log] Sucesso: Indicação criada no banco -> ID: ${lead.id}`,
            );
            success = true;
        } else {
            console.log(`[Backend Log] Erro: Nome e telefone não fornecidos.`);
            errorMsg = "Nome e telefone são obrigatórios.";
        }
    } catch (error: any) {
        errorMsg = "Ocorreu um erro ao enviar sua indicação. Tente novamente.";
        console.error("[Backend Log] Erro crítico ao salvar lead:", error);
    }
}
---

<Layout title={`Indicação de ${partnerName}`}>
    <div
        class="min-h-screen flex flex-col font-sans bg-slate-50 relative overflow-hidden"
    >
        {/* Background Gradients */}
        <div class="absolute inset-0 pointer-events-none z-0">
            <div
                class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] rounded-full bg-gradient-to-br from-yellow-400/20 to-primary/10 blur-[80px]"
            >
            </div>
            <div
                class="absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-blue-500/10 to-transparent blur-[100px]"
            >
            </div>
        </div>

        {/* Header Sticky Glassmorphism */}
        <header
            class="sticky top-0 z-50 h-20 w-full backdrop-blur-md bg-white/70 border-b border-white/40 shadow-sm"
        >
            <div
                class="max-w-[1200px] mx-auto h-full px-6 flex justify-between items-center"
            >
                <div class="flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-xl bg-gradient-to-br from-yellow-400 to-primary flex items-center justify-center shadow-lg shadow-primary/30"
                    >
                        <span class="text-xl">⚡</span>
                    </div>
                    <span
                        class="font-outfit font-extrabold text-lg text-slate-900 tracking-tight"
                        >Assina Comigo</span
                    >
                </div>
                <div
                    class="hidden sm:flex items-center gap-2 bg-white/50 backdrop-blur-sm border border-slate-200/60 px-4 py-1.5 rounded-full text-sm font-medium text-slate-700 shadow-sm"
                >
                    <span>🤝</span>
                    Indicação de <strong class="text-slate-900"
                        >{partnerName}</strong
                    >
                </div>
            </div>
        </header>

        {/* Mobile Badge Area */}
        <div class="sm:hidden w-full flex justify-center mt-6 z-10 px-4">
            <div
                class="inline-flex items-center gap-2 bg-white/60 backdrop-blur-md border border-slate-200/50 px-5 py-2 rounded-full text-sm font-medium text-slate-700 shadow-sm"
            >
                <span>🤝</span>
                Recomendado por <strong class="text-slate-900"
                    >{partnerName}</strong
                >
            </div>
        </div>

        <main
            class="flex-1 w-full max-w-2xl mx-auto px-5 py-8 md:py-16 flex flex-col gap-10 z-10 relative"
        >
            {/* Hero Section */}
            <div class="text-center flex flex-col items-center">
                <div class="mb-6 drop-shadow-2xl">
                    <img
                        src="/src/assets/illustrations/complete-design.svg"
                        alt="Ilustração Exclusiva"
                        class="w-full max-w-[280px] md:max-w-[320px] mx-auto hover:-translate-y-2 transition-transform duration-500 ease-out"
                    />
                </div>
                <h1
                    class="text-4xl md:text-5xl font-black tracking-tight leading-none text-slate-900 mb-4"
                >
                    Aproveite esta <br class="hidden md:block" />
                    <span
                        class="bg-gradient-to-r from-blue-600 to-indigo-600 text-transparent bg-clip-text"
                        >oportunidade exclusiva</span
                    >
                </h1>
                <p
                    class="text-lg text-slate-600 max-w-lg mx-auto leading-relaxed"
                >
                    O <strong>{partnerName}</strong> indicou você para fazer parte
                    do nosso programa de vantagens. Preencha os dados e entraremos
                    em contato em tempo recorde.
                </p>
            </div>

            {/* Glassmorphic Form Card */}
            <div
                class="bg-white/60 backdrop-blur-xl border border-white/60 rounded-[32px] p-6 md:p-10 shadow-xl shadow-slate-200/50 relative overflow-hidden group"
            >
                <div
                    class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-yellow-400 via-primary to-orange-500"
                >
                </div>

                <div
                    class="flex items-center gap-3 mb-8 pb-6 border-b border-slate-200/50"
                >
                    <div class="p-2.5 bg-blue-50 rounded-2xl text-blue-600">
                        <Sparkles size={24} stroke-width={2.5} />
                    </div>
                    <h3
                        class="text-xl font-extrabold text-slate-900 tracking-tight"
                    >
                        Solicitar Contato
                    </h3>
                </div>

                <form id="leadForm" class="flex flex-col gap-6" method="POST">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="flex flex-col gap-2">
                            <label
                                for="nome"
                                class="text-xs font-bold text-slate-500 uppercase tracking-widest ml-1"
                                >Nome Completo</label
                            >
                            <div class="relative flex items-center">
                                <User
                                    class="absolute left-4 text-slate-400"
                                    size={20}
                                />
                                <input
                                    type="text"
                                    id="nome"
                                    name="nome"
                                    placeholder="Seu nome"
                                    class="w-full h-14 bg-white/70 border border-slate-200/80 rounded-2xl pl-12 pr-4 text-slate-800 placeholder:text-slate-400 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all outline-none"
                                    required
                                />
                            </div>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label
                                for="whatsapp"
                                class="text-xs font-bold text-slate-500 uppercase tracking-widest ml-1"
                                >WhatsApp</label
                            >
                            <div class="relative flex items-center">
                                <Smartphone
                                    class="absolute left-4 text-slate-400"
                                    size={20}
                                />
                                <input
                                    type="tel"
                                    id="whatsapp"
                                    name="whatsapp"
                                    placeholder="(11) 99999-9999"
                                    class="w-full h-14 bg-white/70 border border-slate-200/80 rounded-2xl pl-12 pr-4 text-slate-800 placeholder:text-slate-400 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all outline-none"
                                    required
                                />
                            </div>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label
                                for="local"
                                class="text-xs font-bold text-slate-500 uppercase tracking-widest ml-1"
                                >Bairro / Cidade</label
                            >
                            <div class="relative flex items-center">
                                <MapPin
                                    class="absolute left-4 text-slate-400"
                                    size={20}
                                />
                                <input
                                    type="text"
                                    id="local"
                                    name="local"
                                    placeholder="Ex: Centro, São Paulo"
                                    class="w-full h-14 bg-white/70 border border-slate-200/80 rounded-2xl pl-12 pr-4 text-slate-800 placeholder:text-slate-400 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all outline-none"
                                    required
                                />
                            </div>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label
                                for="cpf"
                                class="text-xs font-bold text-slate-500 uppercase tracking-widest ml-1"
                                >CPF (Opcional)</label
                            >
                            <div class="relative flex items-center">
                                <CreditCard
                                    class="absolute left-4 text-slate-400"
                                    size={20}
                                />
                                <input
                                    type="text"
                                    id="cpf"
                                    name="cpf"
                                    placeholder="000.000.000-00"
                                    class="w-full h-14 bg-white/70 border border-slate-200/80 rounded-2xl pl-12 pr-4 text-slate-800 placeholder:text-slate-400 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all outline-none"
                                />
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-2">
                        <p class="text-[13px] text-slate-500 leading-relaxed">
                            Ao enviar, você concorda com nossos <a
                                href="#"
                                class="font-semibold text-blue-600 hover:text-blue-700 transition-colors"
                                >Termos de Uso</a
                            > e <a
                                href="#"
                                class="font-semibold text-blue-600 hover:text-blue-700 transition-colors"
                                >Política de Privacidade (LGPD)</a
                            >.
                        </p>
                    </div>

                    <button
                        type="submit"
                        class="group relative w-full h-14 md:h-16 flex items-center justify-center gap-2 bg-gradient-to-r from-yellow-400 to-[#FFB918] active:scale-[0.98] transition-transform text-slate-900 font-extrabold text-lg rounded-2xl shadow-[0_8px_25px_-5px_rgba(255,185,24,0.5)] hover:shadow-[0_12px_30px_-5px_rgba(255,185,24,0.6)] overflow-hidden"
                    >
                        {/* Glow effect */}
                        <div
                            class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"
                        >
                        </div>
                        <span class="relative z-10">Quero saber mais!</span>
                        <Send
                            class="relative z-10 group-hover:translate-x-1 transition-transform"
                            size={20}
                        />
                    </button>

                    {
                        errorMsg && (
                            <div class="text-sm text-red-600 font-medium text-center p-4 bg-red-50/80 backdrop-blur-sm border border-red-100 rounded-2xl mt-2">
                                {errorMsg}
                            </div>
                        )
                    }
                </form>

                <div
                    class="success-message"
                    style={`display: ${success ? "flex" : "none"};`}
                    id="successMsg"
                >
                    <div
                        class="flex flex-col items-center justify-center py-8 text-center animate-[bounceIn_0.6s_ease-out]"
                    >
                        <div
                            class="w-20 h-20 bg-gradient-to-br from-green-400 to-green-600 text-white rounded-full flex items-center justify-center text-4xl shadow-lg shadow-green-500/30 mb-6 font-black"
                        >
                            ✓
                        </div>
                        <h3
                            class="text-2xl font-black text-slate-900 mb-3 tracking-tight"
                        >
                            Tudo pronto!
                        </h3>
                        <p
                            class="text-slate-600 leading-relaxed max-w-md mx-auto mb-8 text-lg"
                        >
                            Recebemos seus dados. Um especialista entrará em
                            contato com você nos próximos minutos pelo WhatsApp.
                        </p>
                        <button
                            id="btnOk"
                            class="w-full h-14 bg-slate-100 hover:bg-slate-200 text-slate-800 font-bold rounded-2xl transition-colors"
                        >
                            Entendido
                        </button>
                    </div>
                </div>
            </div>

            {/* Simple FAQ */}
            <div
                class="bg-blue-50/50 backdrop-blur-sm border border-blue-100/50 rounded-[28px] p-8 text-center shadow-inner mt-4"
            >
                <h4 class="font-extrabold text-slate-800 mb-3 text-lg">
                    Por que fui indicado?
                </h4>
                <p class="text-slate-600 leading-relaxed text-[15px]">
                    Nosso parceiro <strong>{partnerName}</strong> acredita que nossas
                    soluções podem ajudar você. Esta é uma rede de confiança onde
                    indicamos apenas oportunidades validas e exclusivas.
                </p>
            </div>
        </main>

        <footer
            class="mt-auto py-8 text-center border-t border-slate-200/50 z-10 relative bg-white/30 backdrop-blur-sm"
        >
            <p
                class="text-[13px] font-medium text-slate-500 uppercase tracking-widest"
            >
                &copy; 2026 Assina Comigo • Todos os direitos reservados
            </p>
        </footer>
    </div>
</Layout>

<script is:inline>
    const form = document.getElementById("leadForm");
    const successMsg = document.getElementById("successMsg");
    const btnOk = document.getElementById("btnOk");

    if (successMsg && successMsg.style.display === "flex") {
        if (form) form.style.display = "none";
    }

    btnOk?.addEventListener("click", () => {
        window.location.href = "https://assina.com.br";
    });
</script>

<style>
    @keyframes bounceIn {
        0% {
            opacity: 0;
            transform: scale(0.8) translateY(20px);
        }
        60% {
            opacity: 1;
            transform: scale(1.05) translateY(-5px);
        }
        100% {
            transform: scale(1) translateY(0);
        }
    }
</style>
