                        tertiary: "#FFBF1A",
                        "tertiary-container": "#FFECAE",
                        "tertiary-fixed": "#FFECAE",
                        "tertiary-fixed-dim": "#FFBF1A"
                    },
                    fontFamily: {
                        headline: ["Plus Jakarta Sans", "sans-serif"],
                        body: ["Manrope", "sans-serif"],
                        label: ["Manrope", "sans-serif"]
                    },
                    borderRadius: {DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", "2xl": "1.5rem", "3xl": "2rem", full: "9999px"},
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-nav {
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            background-color: rgba(255, 255, 255, 0.8); 
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }
        .btn-glow {
            box-shadow: 0 0 25px rgba(96, 40, 255, 0.4);
            animation: pulse-glow 3s infinite alternate;
        }
        @keyframes pulse-glow {
            0% { box-shadow: 0 0 15px rgba(96, 40, 255, 0.2); }
            100% { box-shadow: 0 0 35px rgba(96, 40, 255, 0.6); }
        }
        .ambient-shadow {
            box-shadow: 0 20px 40px -12px rgba(0,0,0,0.8);
        }
    </style>
</head>
<body class="bg-background font-body text-on-surface antialiased selection:bg-primary-container selection:text-slate-900">

    <!-- Navbar -->
    <nav class="fixed top-0 w-full z-50 bg-primary/95 backdrop-blur-md transition-all duration-300 shadow-xl border-b border-white/10">
        <div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
            <div class="flex items-center gap-3">
                <div class="flex h-10 w-auto items-center justify-start -ml-2">
                    <img alt="Ligeira Telecom" class="h-full w-auto object-contain" src={logoLigeiraHorizontal.src} />
                </div>
                <div class="h-6 w-px bg-white/20 mx-1"></div>
                <span class="text-xl font-headline font-black text-white tracking-tighter">Assina Comigo</span>
            </div>
            <div class="hidden md:flex items-center space-x-10 font-label font-bold text-sm tracking-wide text-slate-700">
                <span class="bg-surface-container-high px-4 py-1.5 rounded-full flex items-center gap-2 text-slate-900 shadow-sm border border-black/5">
                    <span class="material-symbols-outlined text-tertiary text-sm">handshake</span>
                    Recomendado por {partnerName}
                </span>
            </div>
            <div class="flex items-center space-x-4">
                <a class="bg-tertiary text-on-tertiary px-6 py-2.5 rounded-full font-headline font-extrabold text-sm hover:scale-105 active:scale-95 transition-all duration-200 btn-glow" href="#signup">
                    Consultar Viabilidade
                </a>
            </div>
        </div>
    </nav>

    <!-- Mobile Partner Badge -->
    <div class="md:hidden pt-24 px-6 flex justify-center w-full">
        <div class="inline-flex items-center justify-center w-full max-w-sm gap-2 bg-white border border-slate-900/10 px-5 py-3 rounded-full text-sm font-bold text-slate-900 shadow-lg">
            <span class="material-symbols-outlined text-tertiary">handshake</span>
            Convite especial de {partnerName}
        </div>
    </div>

    <!-- Hero Section -->
    <header class="relative pt-40 pb-24 overflow-hidden" style="background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%);">
        <div class="max-w-7xl mx-auto px-6 grid xl:grid-cols-2 gap-16 items-center">
            
            <div class="z-10 relative">
                <!-- Decorative Glow Behind Text -->
                <div class="absolute -top-32 -left-32 w-96 h-96 bg-tertiary/20 rounded-full blur-[100px] pointer-events-none"></div>

                <div class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-primary/90 text-white font-label font-bold text-[11px] uppercase tracking-[0.15em] mb-8 mt-4 md:mt-0 shadow-lg shadow-primary/20">
                    <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
                    Oferta Exclusiva 
                </div>
                
                <h1 class="text-5xl lg:text-[72px] font-headline font-black text-slate-900 leading-[1.05] tracking-tighter mb-8">
                    Indicação do seu amigo <span class="text-primary italic">{partner?.nome || 'Consultor'}</span>
                </h1>
                
                <p class="text-xl text-on-surface-variant mb-12 max-w-xl leading-relaxed font-body">
                    <strong>{partnerName}</strong> liberou um convite exclusivo para você ter a verdadeira fibra ótica em sua casa. Jogue online sem lag e assista filmes em 4K.
                </p>
                
                <div class="flex flex-col sm:flex-row gap-5 items-start sm:items-center">
                    <a class="w-full sm:w-auto text-center bg-tertiary text-on-tertiary px-10 py-4 rounded-full font-headline font-extrabold text-lg hover:scale-[1.03] active:scale-95 transition-all btn-glow shadow-xl shadow-tertiary/20" href="#signup">
                        Quero verificar viabilidade
                    </a>
                </div>
                
                <div class="mt-12 flex items-center gap-4 text-sm text-on-surface-variant font-label">
                    <div class="flex -space-x-3">
                        <img class="w-10 h-10 border-2 border-background rounded-full" src="https://i.pravatar.cc/100?img=1" alt="User">
                        <img class="w-10 h-10 border-2 border-background rounded-full" src="https://i.pravatar.cc/100?img=2" alt="User">
                        <img class="w-10 h-10 border-2 border-background rounded-full" src="https://i.pravatar.cc/100?img=3" alt="User">
                        <div class="w-10 h-10 border-2 border-background rounded-full bg-white flex items-center justify-center text-xs font-bold text-slate-900">+10k</div>
                    </div>
                    <p>Clientes conectados <br/>em nossa fibra ótica.</p>
                </div>
            </div>

            <div class="relative z-10 w-full flex justify-center xl:justify-end mt-12 xl:mt-0">
                <div class="relative w-full max-w-md">
                    <div class="absolute inset-0 bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>

                    <!-- Ligia Image Hero -->
                    <div class="relative z-20 flex justify-center items-end h-[500px]">
                        <img alt="Lígia - Embaixadora Ligeira Telecom" src={ligiaHeroImage.src} class="h-[120%] w-auto object-cover max-w-none ambient-shadow drop-shadow-2xl translate-y-8" />
                    </div>

                    <!-- Logo Horizontal Display -->
                    <div class="absolute -bottom-16 -right-4 md:-right-12 bg-white p-6 py-8 rounded-3xl ambient-shadow border border-slate-900/5 z-30 transform rotate-3">
                        <img alt="Ligeira Telecom" src={logoLigeiraHorizontal.src} class="h-16 object-contain" />
                    </div>

                </div>
            </div>
        </div>
    </header>

    <!-- Seção de Diferenciais (Cards) -->
    <section class="py-12 -mt-12 relative z-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Card 1 -->
                <div class="group relative bg-surface-container p-10 rounded-[2rem] border border-slate-900/5 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300">
                    <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-primary transition-all duration-300">
                        <span class="material-symbols-outlined text-primary text-3xl group-hover:text-white transition-colors duration-300">rocket_launch</span>
                    </div>
                    <h4 class="text-2xl font-headline font-black mb-3 text-slate-900">Ultra Velocidade</h4>
                    <p class="text-on-surface-variant leading-relaxed">Fibra óptica pura de ponta a ponta. Jogue, asista e trabalhe sem quedas ou lentidão.</p>
                </div>

                <!-- Card 2 -->
                <div class="group relative bg-surface-container p-10 rounded-[2rem] border border-slate-900/5 hover:border-tertiary/50 hover:shadow-xl hover:shadow-tertiary/10 transition-all duration-300">
                    <div class="w-16 h-16 rounded-2xl bg-tertiary shadow-lg shadow-tertiary/20 flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-yellow-400 transition-all duration-300">
                        <span class="material-symbols-outlined text-slate-900 text-3xl">verified</span>
                    </div>
                    <h4 class="text-2xl font-headline font-black mb-3 text-slate-900">Estabilidade Real</h4>
                    <p class="text-on-surface-variant leading-relaxed">Nada de robôs. Atendimento humanizado e técnico disponível em minutos para você.</p>
                </div>

                <!-- Card 3 -->
                <div class="group bg-white/80 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white shadow-2xl shadow-primary/5 hover:bg-white hover:shadow-primary/10 transition-all duration-300">
                    <div class="w-14 h-14 bg-tertiary/10 rounded-2xl flex items-center justify-center mb-6 text-slate-900 group-hover:scale-110 group-hover:bg-tertiary group-hover:text-on-tertiary transition-all duration-300">
                        <span class="material-symbols-outlined text-3xl">verified</span>
                    </div>
                    <h4 class="text-2xl font-headline font-black text-slate-900 mb-3 tracking-tight">Zero Estresse</h4>
                    <p class="text-on-surface-variant leading-relaxed">Cancele quando quiser, mude quando quiser. Transparência total e preço justo sempre.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Sign Up Form / Final CTA Section -->
    <section class="py-24 relative overflow-hidden" id="signup">
        <div class="absolute inset-0 bg-[#F8FAFC] pointer-events-none border-t border-slate-900/5"></div>
        <div class="absolute -bottom-[500px] left-[10%] w-[1000px] h-[1000px] bg-primary-container/5 rounded-full blur-[150px] pointer-events-none"></div>
        
        <div class="max-w-4xl mx-auto px-6 relative z-10">
            <div class="bg-surface-container-lowest p-8 md:p-14 lg:p-16 rounded-[3rem] shadow-2xl shadow-black/50 border border-slate-900/5 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-white/[0.03] to-transparent pointer-events-none"></div>

                {success ? (
                    <div class="text-center py-10 relative z-10 flex flex-col items-center">
                        <div class="w-24 h-24 bg-green-500/20 rounded-full flex items-center justify-center mb-8 mx-auto animate-bounce" style="animation-duration: 2s;">
                            <span class="material-symbols-outlined text-green-400 text-5xl">check_circle</span>
                        </div>
                        <h2 class="text-4xl lg:text-5xl font-headline font-black text-slate-900 tracking-tight mb-4">Tudo Certo!</h2>
                        <p class="text-on-surface-variant text-xl max-w-lg mx-auto">Sua pré-aprovação foi enviada via indicação oficial de <strong>{partnerName}</strong>. Em instantes, nosso time entrará em contato via WhatsApp para finalizar tudo.</p>
                        <a href="/" class="mt-10 inline-block bg-surface-container-high text-slate-900 px-8 py-4 rounded-full font-headline font-bold hover:bg-surface-container-highest transition-colors">Voltar para o site inicial</a>
                    </div>
                ) : (
                    <>
                        <div class="text-center mb-12 relative z-10">
                            <h2 class="text-3xl md:text-5xl font-headline font-black text-slate-900 tracking-tight mb-4">Vem ser Ligeira!</h2>
                            <p class="text-on-surface-variant text-lg">Preencha o formulário rápido abaixo para solicitar sua instalação com a recomendação de {partnerName}.</p>
                        </div>

                        {errorMsg && (
                            <div class="mb-8 p-4 bg-red-500/10 border border-red-500/20 rounded-2xl flex items-center gap-3">
                                <span class="material-symbols-outlined text-red-500">error</span>
                                <p class="text-red-400 font-bold text-sm">{errorMsg}</p>
                            </div>
                        )}

                        <form class="grid md:grid-cols-2 gap-6 relative z-10" id="leadForm" method="POST">
                            <div class="md:col-span-2">
                                <label for="nome" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">Nome Completo</label>
                                <input id="nome" name="nome" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" placeholder="Qual o seu nome?" type="text" required/>
                            </div>
                            
                            <div>
                                <label for="whatsapp" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">WhatsApp</label>
                                <input id="whatsapp" name="whatsapp" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" placeholder="(00) 00000-0000" inputmode="numeric" type="tel" required/>
                            </div>

                            <div>
                                <label for="cpf" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">CPF (Opcional)</label>
                                <input id="cpf" name="cpf" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" placeholder="Para agilizar o cadastro" inputmode="numeric" type="text"/>
                            </div>

                            <div class="grid md:grid-cols-3 gap-6 md:col-span-2">
                                <div>
                                    <label for="cep" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">CEP</label>
                                    <input id="cep" name="cep" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" placeholder="00000-000" type="text" required/>
                                </div>
                                <div class="md:col-span-2">
                                    <label for="logradouro" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">Logradouro (Rua/Av)</label>
                                    <input id="logradouro" name="logradouro" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" placeholder="Nome da rua" type="text" required/>
                                </div>
                            </div>

                            <div class="grid md:grid-cols-2 gap-6 md:col-span-2">
                                <div>
                                    <label for="numero" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">Número</label>
                                    <input id="numero" name="numero" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" placeholder="123" type="text" required/>
                                </div>
                                <div>
                                    <label for="bairro" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">Bairro</label>
                                    <input id="bairro" name="bairro" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" placeholder="Seu bairro" type="text" required/>
                                </div>
                            </div>

                            <div class="grid md:grid-cols-2 gap-6 md:col-span-2">
                                <div>
                                    <label for="cidade" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">Cidade (Cariri)</label>
                                    <select id="cidade" name="cidade" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" required>
                                        <option value="">Selecione a cidade</option>
                                        <option value="Juazeiro do Norte">Juazeiro do Norte</option>
                                        <option value="Crato">Crato</option>
                                        <option value="Barbalha">Barbalha</option>
                                    </select>
                                </div>
                                <div>
                                    <label for="complemento" class="block text-sm font-label font-bold text-on-surface-variant mb-2 ml-1">Complemento (Opcional)</label>
                                    <input id="complemento" name="complemento" class="w-full bg-surface-container-highest border-none rounded-2xl py-4 px-6 text-slate-900 focus:ring-2 focus:ring-primary-container transition-all" placeholder="Apto, Bloco, etc" type="text"/>
                                </div>
                            </div>
                            
                            <div class="md:col-span-2 mt-8">
                                <button class="w-full bg-tertiary text-on-tertiary py-5 rounded-[1.5rem] font-headline font-black text-xl hover:scale-[1.02] active:scale-98 transition-all btn-glow shadow-xl flex items-center justify-center gap-3" type="submit">
                                    <span class="material-symbols-outlined">rocket_launch</span>
                                    Garantir minha vaga
                                </button>
                                <p class="text-center text-sm text-on-surface-variant mt-6 flex flex-col items-center justify-center gap-2">
                                    Nossos consultores não cobram NADA durante o contato.
                                    <span class="flex items-center gap-1 text-green-500 font-bold bg-green-500/10 px-3 py-1 rounded-full">
                                        <span class="material-symbols-outlined text-[16px]">verified</span> Instalação Segura
                                    </span>
                                </p>
                            </div>
                        </form>
                    </>
                )}
            </div>
        </div>
    </section>

    <script is:inline>
        // Máscaras de input para WhatsApp, CPF e CEP
        function sanitizePhone(phone) {
            if (!phone) return '';
            const digitsOnly = phone.replace(/\D/g, '');
            if (digitsOnly.length === 13 && digitsOnly.startsWith('55')) {
                return digitsOnly.slice(2);
            }
            return digitsOnly;
        }

        function formatPhoneDisplay(phone) {
            const digits = sanitizePhone(phone).slice(0, 11);
            if (!digits) return '';
            if (digits.length <= 2) return `(${digits}`;
            if (digits.length <= 6) return `(${digits.slice(0, 2)}) ${digits.slice(2)}`;
            if (digits.length <= 10) return `(${digits.slice(0, 2)}) ${digits.slice(2, 6)}-${digits.slice(6)}`;
            return `(${digits.slice(0, 2)}) ${digits.slice(2, 7)}-${digits.slice(7)}`;
        }

        function sanitizeCPF(cpf) {
            if (!cpf) return '';
            return cpf.replace(/\D/g, '');
        }

        function formatCPFDisplay(cpf) {
            const digits = sanitizeCPF(cpf).slice(0, 11);
            if (!digits) return '';
            if (digits.length <= 3) return digits;
            if (digits.length <= 6) return `${digits.slice(0, 3)}.${digits.slice(3)}`;
            if (digits.length <= 9) return `${digits.slice(0, 3)}.${digits.slice(3, 6)}.${digits.slice(6)}`;
            return `${digits.slice(0, 3)}.${digits.slice(3, 6)}.${digits.slice(6, 9)}-${digits.slice(9)}`;
        }

        function formatCEPDisplay(cep) {
            const digits = cep.replace(/\D/g, '').slice(0, 8);
            if (!digits) return '';
            if (digits.length <= 5) return digits;
            return `${digits.slice(0, 5)}-${digits.slice(5)}`;
        }

        async function fetchAddress(cep) {
            const cleanCEP = cep.replace(/\D/g, '');
            if (cleanCEP.length !== 8) return;

            const cepInput = document.getElementById('cep');
            const logradouroInput = document.getElementById('logradouro');
            const bairroInput = document.getElementById('bairro');
            const cidadeSelect = document.getElementById('cidade');
            const submitBtn = document.querySelector('button[type="submit"]');

            cepInput.classList.add('animate-pulse');

            try {
                const response = await fetch(`https://viacep.com.br/ws/${cleanCEP}/json/`);
                const data = await response.json();

                if (data.erro) {
                    alert("CEP não encontrado.");
                    return;
                }

                const allowedCities = ["Juazeiro do Norte", "Crato", "Barbalha"];
                const cityMatch = allowedCities.find(c => c.toLowerCase() === data.localidade.toLowerCase());

                if (!cityMatch) {
                    alert("A Ligeira ainda não atende em " + data.localidade + ". Atendemos apenas Juazeiro do Norte, Crato e Barbalha.");
                    cidadeSelect.value = "";
                    submitBtn.disabled = true;
                    submitBtn.style.opacity = "0.5";
                    return;
                }

                submitBtn.disabled = false;
                submitBtn.style.opacity = "1";
                logradouroInput.value = data.logradouro || "";
                bairroInput.value = data.bairro || "";
                cidadeSelect.value = cityMatch;

            } catch (error) {
                console.error("Erro ao buscar CEP:", error);
            } finally {
                cepInput.classList.remove('animate-pulse');
            }
        }

        function applyPhoneMask(input) {
            if (!input) return;
            input.addEventListener('input', function() {
                this.value = formatPhoneDisplay(this.value);
            });
        }

        function applyCPFMask(input) {
            if (!input) return;
            input.addEventListener('input', function() {
                this.value = formatCPFDisplay(this.value);
            });
        }

        function applyCEPMask(input) {
            if (!input) return;
            input.addEventListener('input', function() {
                this.value = formatCEPDisplay(this.value);
                if (this.value.replace(/\D/g, '').length === 8) {
                    fetchAddress(this.value);
                }
            });
        }

        // Aplica máscaras quando o DOM estiver pronto
        document.addEventListener('DOMContentLoaded', function() {
            applyPhoneMask(document.getElementById("whatsapp"));
            applyCPFMask(document.getElementById("cpf"));
            applyCEPMask(document.getElementById("cep"));
        });
    </script>

    <!-- Become a Partner CTA Section -->
