---
import Layout from "../../layouts/Layout.astro";
import { captacaoService } from "../../services/captacaoService";
import { Users, Award, DollarSign, Star, ArrowRight, Shield } from "@lucide/astro";

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect("/404");
}

// Busca o contexto de captação pelo slug do grupo
const contexto = await captacaoService.getCaptacaoContext(slug);

if (!contexto) {
    return Astro.redirect("/404?error=grupo_nao_encontrado");
}

const isMoneyGroup = contexto.tipoRemuneracao === "dinheiro";
const recompensaFormatada = isMoneyGroup
    ? new Intl.NumberFormat("pt-BR", { style: "currency", currency: "BRL" }).format(contexto.valorRecompensa)
    : `${contexto.valorRecompensa} pontos`;

// URL de registro com o grupo_id e o slug embutidos como query params
const registroUrl = `/parceiro/registro?grupo_id=${contexto.grupoId}&grupo_slug=${contexto.grupoSlug}`;
---

<Layout title={`Grupo ${contexto.grupoNome} - Assina Comigo`}>
    <div class="min-h-screen flex flex-col bg-slate-950 relative overflow-hidden">

        {/* Orbs de fundo */}
        <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden">
            <div class={`absolute top-[-20%] right-[-10%] w-[700px] h-[700px] rounded-full blur-[120px] opacity-20 ${isMoneyGroup ? 'bg-emerald-500' : 'bg-violet-600'}`}></div>
            <div class={`absolute bottom-[-20%] left-[-10%] w-[600px] h-[600px] rounded-full blur-[100px] opacity-15 ${isMoneyGroup ? 'bg-yellow-500' : 'bg-blue-600'}`}></div>
        </div>

        {/* Header */}
        <header class="relative z-10 w-full py-6 px-6 flex items-center justify-center border-b border-white/5">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-yellow-400 to-amber-500 flex items-center justify-center shadow-lg shadow-amber-500/30">
                    <span class="text-lg font-black text-slate-900">⚡</span>
                </div>
                <span class="font-extrabold text-white text-lg tracking-tight">Assina Comigo</span>
            </div>
        </header>

        <main class="relative z-10 flex-1 w-full max-w-2xl mx-auto px-5 py-12 flex flex-col gap-8">

            {/* Badge do tipo de grupo */}
            <div class="flex justify-center">
                <div class={`inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold border ${isMoneyGroup ? 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400' : 'bg-violet-500/10 border-violet-500/30 text-violet-400'}`}>
                    {isMoneyGroup ? <DollarSign size={15} /> : <Star size={15} />}
                    {isMoneyGroup ? "Remuneração em Dinheiro" : "Remuneração em Pontos"}
                </div>
            </div>

            {/* Card Principal */}
            <div class="bg-white/5 border border-white/10 rounded-3xl p-8 md:p-10 backdrop-blur-xl shadow-2xl shadow-black/40">

                {/* Topo com ícone e nome do grupo */}
                <div class="flex flex-col items-center text-center gap-4 mb-8 pb-8 border-b border-white/10">
                    <div class={`w-20 h-20 rounded-2xl flex items-center justify-center shadow-2xl ${isMoneyGroup ? 'bg-gradient-to-br from-emerald-400 to-emerald-600 shadow-emerald-500/30' : 'bg-gradient-to-br from-violet-500 to-indigo-600 shadow-violet-500/30'}`}>
                        {isMoneyGroup
                            ? <DollarSign size={36} class="text-white" />
                            : <Award size={36} class="text-white" />
                        }
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-slate-400 uppercase tracking-widest mb-1">Você foi convidado para o grupo</p>
                        <h1 class="text-3xl md:text-4xl font-black text-white tracking-tight">{contexto.grupoNome}</h1>
                    </div>
                </div>

                {/* Detalhes de recompensa */}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                    <div class={`md:col-span-2 rounded-[24px] p-6 flex flex-col items-center text-center ${isMoneyGroup ? 'bg-emerald-500/10 border border-emerald-500/20' : 'bg-violet-500/10 border border-violet-500/20'}`}>
                        <span class="text-sm font-bold uppercase tracking-widest mb-2 text-slate-400">Aqui você ganha</span>
                        <p class={`text-4xl md:text-5xl font-black mb-2 ${isMoneyGroup ? 'text-emerald-400' : 'text-violet-400'}`}>
                            {recompensaFormatada}
                        </p>
                        <p class="text-sm text-slate-300">por cada indicação sua que se tornar cliente.</p>
                    </div>

                    {(contexto as any).grupoDescricao && (
                        <div class="md:col-span-2 rounded-2xl p-5 flex items-start gap-4 bg-white/5 border border-white/10">
                            <div class="w-12 h-12 rounded-xl bg-yellow-500/20 flex items-center justify-center flex-shrink-0">
                                <span class="text-yellow-400 text-lg">💡</span>
                            </div>
                            <div>
                                <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Regras e Vantagens</p>
                                <p class="text-sm text-slate-300 mt-1 leading-relaxed">{(contexto as any).grupoDescricao}</p>
                            </div>
                        </div>
                    )}

                    <div class="rounded-2xl p-5 flex items-start gap-4 bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
                        <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center flex-shrink-0">
                            <Users size={24} class="text-blue-400" />
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase tracking-wider text-slate-400">1. Indique com seu link</p>
                            <p class="text-sm text-slate-300 mt-1 leading-relaxed">
                                Você receberá um link 100% personalizado. É só enviar para amigos e contatos pelo WhatsApp.
                            </p>
                        </div>
                    </div>

                    <div class="rounded-2xl p-5 flex items-start gap-4 bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center flex-shrink-0">
                            <DollarSign size={24} class="text-emerald-400" />
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase tracking-wider text-slate-400">2. Ganhe comissões</p>
                            <p class="text-sm text-slate-300 mt-1 leading-relaxed">
                                A cada contrato fechado através de você, a recompensa cai direto no seu painel.
                            </p>
                        </div>
                    </div>
                    
                    <div class="md:col-span-2 rounded-2xl p-5 flex items-start gap-4 bg-gradient-to-r from-slate-800 to-slate-900 border border-slate-700">
                        <div class="w-12 h-12 rounded-xl bg-yellow-400/20 flex items-center justify-center flex-shrink-0">
                            <Shield size={24} class="text-yellow-400" />
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase tracking-wider text-yellow-400">Acesso Exclusivo e Restrito</p>
                            <p class="text-sm text-slate-300 mt-1 leading-relaxed">
                                O Assina Comigo funciona apenas por convite. Ao fazer o cadastro nesta página, você garante sua vaga exclusiva no grupo <strong class="text-white">{contexto.grupoNome}</strong>.
                            </p>
                        </div>
                    </div>
                </div>


                {/* CTA */}
                <a
                    href={registroUrl}
                    class={`group relative w-full h-14 md:h-16 flex items-center justify-center gap-3 font-extrabold text-base md:text-lg rounded-2xl overflow-hidden transition-all active:scale-[0.98] shadow-2xl ${isMoneyGroup ? 'bg-gradient-to-r from-emerald-500 to-green-500 shadow-emerald-500/30 text-white hover:shadow-emerald-500/50' : 'bg-gradient-to-r from-violet-600 to-indigo-600 shadow-violet-500/30 text-white hover:shadow-violet-500/50'}`}
                >
                    <div class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
                    <span class="relative z-10">Quero fazer parte!</span>
                    <ArrowRight class="relative z-10 group-hover:translate-x-1 transition-transform" size={22} />
                </a>

                <p class="text-center text-xs text-slate-500 mt-4">
                    Já tem conta?
                    <a href="/parceiro/login" class="text-slate-400 font-semibold hover:text-white transition-colors ml-1">Entrar no painel</a>
                </p>
            </div>

            {/* Rodapé info */}
            <p class="text-center text-xs text-slate-600">
                © 2026 Assina Comigo · Plataforma de Indicações
            </p>
        </main>
    </div>
</Layout>
