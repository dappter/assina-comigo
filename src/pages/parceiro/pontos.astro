---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { partnerService } from "../../services/partnerService";
import { rewardService } from "../../services/rewardService";

const tenantId = Astro.locals.tenantId;
const profileId = Astro.locals.profileId;

if (!tenantId || !profileId) {
    return Astro.redirect("/parceiro/login");
}

const partner = await partnerService.getPartnerById(tenantId, profileId);
const userName = partner?.nome || "Parceiro";
const userAvatar = userName.substring(0, 2).toUpperCase();

// Buscar recompensas do tipo pontos
const rewards = await rewardService.getRewards(tenantId, profileId);
const pointsRewards = rewards.filter(
    (r) => r.tipo?.toLowerCase() === "pontos" || r.tipo?.toLowerCase() === "pontos",
);
const saldoPontos = partner?.saldo_pontos || 0;
const pontosPendentes = pointsRewards.reduce((acc, r) => {
    return r.status?.toLowerCase() === "a_pagar" || r.status?.toLowerCase() === "pendente" ? acc + (r.valor || 0) : acc;
}, 0);

const formatDate = (d: string) =>
    new Date(d).toLocaleDateString("pt-BR", {
        day: "2-digit",
        month: "short",
        year: "numeric",
    });
---

<DashboardLayout
    title="Meus Pontos"
    userName={userName}
    userAvatar={userAvatar}
>
    <div class="pontos-page">
        <header class="page-header">
            <div>
                <h1 class="page-title">Meus Pontos</h1>
                <p class="subtitle">
                    Acompanhe seu saldo e histórico de pontos acumulados.
                </p>
            </div>
        </header>

        <!-- Cards de saldo -->
        <div class="saldo-grid">
            <div class="saldo-card saldo-total">
                <div class="saldo-icon">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><polygon
                            points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
                        ></polygon></svg
                    >
                </div>
                <div class="saldo-info">
                    <span class="saldo-label">Saldo Disponível</span>
                    <strong class="saldo-value">{saldoPontos} pts</strong>
                </div>
            </div>
            <div class="saldo-card saldo-pendente">
                <div class="saldo-icon">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><circle cx="12" cy="12" r="10"></circle><polyline
                            points="12 6 12 12 16 14"></polyline></svg
                    >
                </div>
                <div class="saldo-info">
                    <span class="saldo-label">Pontos Pendentes</span>
                    <strong class="saldo-value">{pontosPendentes} pts</strong>
                </div>
            </div>
        </div>

        <!-- Como ganhar pontos -->
        <section class="how-card">
            <h2 class="how-title">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><circle cx="12" cy="12" r="10"></circle><path
                        d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line
                        x1="12"
                        y1="17"
                        x2="12.01"
                        y2="17"></line></svg
                >
                Como ganhar pontos?
            </h2>
            <ul class="how-list">
                <li>
                    <span class="how-step">1</span>
                    <p>
                        Compartilhe seu link de indicação com amigos e
                        conhecidos.
                    </p>
                </li>
                <li>
                    <span class="how-step">2</span>
                    <p>O indicado preenche o formulário e vira um lead.</p>
                </li>
                <li>
                    <span class="how-step">3</span>
                    <p>
                        Quando o serviço for <strong>instalado</strong>, você
                        ganha os pontos!
                    </p>
                </li>
            </ul>
            <a href="/parceiro/dashboard" class="cta-link">
                Copiar meu link de indicação →
            </a>
        </section>

        <!-- Histórico de pontos -->
        <section class="history-section">
            <h2 class="section-title">Histórico</h2>
            {
                pointsRewards.length === 0 ? (
                    <div class="empty-state">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="48"
                            height="48"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.25"
                        >
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                        </svg>
                        <h3>Nenhum ponto ainda</h3>
                        <p>
                            Suas recompensas em pontos aparecerão aqui após as
                            instalações.
                        </p>
                        <a href="/parceiro/dashboard" class="btn-primary-sm">
                            Ver meu link de indicação
                        </a>
                    </div>
                ) : (
                    <div class="history-list">
                        {pointsRewards.map((r) => (
                            <div class="history-item">
                                <div class="history-icon">⭐</div>
                                <div class="history-info">
                                    <span class="history-label">
                                        Comissão #{r.id.slice(0, 8)}
                                    </span>
                                    <span class="history-date">
                                        {formatDate(r.created_at)}
                                    </span>
                                </div>
                                <div class="history-right">
                                    <strong class="history-pts">
                                        +{r.valor || 0} pts
                                    </strong>
                                    <span
                                        class={`status-badge ${r.status?.toLowerCase() === "pago" || r.status?.toLowerCase() === "creditado" ? "paid" : "pending"}`}
                                    >
                                        {r.status || "Pendente"}
                                    </span>
                                </div>
                            </div>
                        ))}
                    </div>
                )
            }
        </section>
    </div>
</DashboardLayout>

<style>
    .pontos-page {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        max-width: 720px;
    }
    .page-header {
        margin-bottom: 0;
    }
    .page-title {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }
    .subtitle {
        color: var(--color-subtle);
        margin-top: 0.25rem;
    }

    .saldo-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }
    .saldo-card {
        border-radius: var(--radius-2xl);
        padding: 1.75rem;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        color: #fff;
    }
    .saldo-total {
        background: linear-gradient(135deg, #ffb918 0%, #f59e0b 100%);
        box-shadow: 0 8px 25px rgba(255, 185, 24, 0.35);
    }
    .saldo-pendente {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .saldo-icon {
        width: 52px;
        height: 52px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .saldo-label {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        opacity: 0.8;
        display: block;
        margin-bottom: 0.25rem;
    }
    .saldo-value {
        font-size: 2rem;
        font-weight: 900;
        font-family: "Outfit", sans-serif;
        letter-spacing: -0.03em;
    }

    /* Como ganhar */
    .how-card {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .how-title {
        font-size: 1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
    }
    .how-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .how-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.875rem;
    }
    .how-step {
        width: 28px;
        height: 28px;
        background: var(--color-brand-primary-light);
        color: var(--color-brand-primary-dark);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 800;
        flex-shrink: 0;
    }
    .how-list p {
        font-size: 0.9rem;
        color: var(--color-body);
        line-height: 1.5;
        padding-top: 4px;
    }
    .cta-link {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--color-brand-secondary);
    }
    .cta-link:hover {
        text-decoration: underline;
    }

    /* Histórico */
    .section-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
    }
    .history-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        overflow: hidden;
    }
    .history-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--color-border);
        transition: var(--transition-fast);
    }
    .history-item:last-child {
        border-bottom: none;
    }
    .history-item:hover {
        background: var(--color-bg-alt);
    }
    .history-icon {
        width: 40px;
        height: 40px;
        background: var(--color-brand-primary-light);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
    .history-info {
        flex: 1;
    }
    .history-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-heading);
    }
    .history-date {
        font-size: 0.78rem;
        color: var(--color-subtle);
    }
    .history-right {
        text-align: right;
    }
    .history-pts {
        display: block;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--color-brand-primary-dark);
    }
    .status-badge {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 0.15rem 0.6rem;
        border-radius: var(--radius-full);
    }
    .status-badge.paid {
        background: #d1fae5;
        color: #065f46;
    }
    .status-badge.pending {
        background: #fef3c7;
        color: #92400e;
    }

    /* Empty state */
    .empty-state {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: 3rem 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        color: var(--color-subtle);
    }
    .empty-state h3 {
        font-size: 1.125rem;
        color: var(--color-heading);
        margin: 0;
    }
    .empty-state p {
        font-size: 0.9rem;
        max-width: 280px;
    }
    .btn-primary-sm {
        margin-top: 0.5rem;
        padding: 0.625rem 1.5rem;
        background: var(--color-brand-primary);
        color: #111827;
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-weight: 700;
        text-decoration: none;
        transition: var(--transition-fast);
    }
    .btn-primary-sm:hover {
        background: var(--color-brand-primary-dark);
        color: #111827;
    }

    @media (max-width: 600px) {
        .saldo-grid {
            grid-template-columns: 1fr;
        }
        .saldo-value {
            font-size: 1.6rem;
        }
    }
</style>
