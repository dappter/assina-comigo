---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { partnerService } from "../../services/partnerService";
import { indicationService } from "../../services/indicationService";
import { rewardService } from "../../services/rewardService";

const tenantId = Astro.locals.tenantId;
const profileId = Astro.locals.profileId;

if (!tenantId || !profileId) {
    return Astro.redirect("/parceiro/login");
}

const partner = await partnerService.getPartnerById(tenantId, profileId);
const userName = partner?.nome || "Parceiro";
const userAvatar = userName.substring(0, 2).toUpperCase();

// Montar notificações baseadas em dados reais
interface Notificacao {
    id: string;
    tipo: "sucesso" | "info" | "alerta";
    titulo: string;
    descricao: string;
    data: string;
    link: string;
}

const notificacoes: Notificacao[] = [];

// Indicações recentes (últimas 5)
try {
    const leads = await indicationService.getIndications(tenantId, profileId);
    const recentes = leads.slice(0, 5);
    recentes.forEach((l) => {
        notificacoes.push({
            id: `lead-${l.id}`,
            tipo: l.status === "Instalado" ? "sucesso" : "info",
            titulo:
                l.status === "Instalado"
                    ? `🎉 ${l.nome} foi instalado!`
                    : `Nova indicação: ${l.nome}`,
            descricao:
                l.status === "Instalado"
                    ? "Parabéns! Você gerou uma comissão com essa indicação."
                    : `Status atual: ${l.status || "Recebido"}`,
            data: l.created_at,
            link: `/parceiro/indicados/${l.id}`,
        });
    });
} catch {
    // silencia erros de fetch
}

// Ganhos pendentes (em a_pagar)
try {
    const rewards = await rewardService.getRewards(tenantId, profileId);
    const pendentes = rewards
        .filter((r) => r.status?.toLowerCase() === "pendente")
        .slice(0, 3);
    pendentes.forEach((r) => {
        notificacoes.push({
            id: `reward-${r.id}`,
            tipo: "alerta",
            titulo: "Comissão aguardando pagamento",
            descricao: `Valor: R$ ${(r.valor || 0).toFixed(2).replace(".", ",")} — aguardando liberação.`,
            data: r.created_at,
            link: "/parceiro/ganhos",
        });
    });

    // ─── NOTIFICAÇÕES DE PAGAMENTO RECEBIDO ────────────────────────────────
    // Exibe confirmação quando uma comissão foi marcada como 'pago' pelo admin.
    const pagas = rewards
        .filter((r) => r.status?.toLowerCase() === "pago")
        .slice(0, 5);
    pagas.forEach((r) => {
        const isPontos = r.tipo?.toLowerCase() === "pontos";
        const valorFormatado = isPontos
            ? `${r.valor || 0} pontos`
            : `R$ ${(r.valor || 0).toFixed(2).replace(".", ",")}`;
        notificacoes.push({
            id: `pago-${r.id}`,
            tipo: "sucesso",
            titulo: `💸 Pagamento recebido!`,
            descricao: `Você recebeu ${valorFormatado} referente a uma indicação aprovada.`,
            data: r.created_at,
            link: isPontos ? "/parceiro/pontos" : "/parceiro/ganhos",
        });
    });
} catch {
    // silencia
}


// Ordenar por data mais recente
notificacoes.sort(
    (a, b) => new Date(b.data).getTime() - new Date(a.data).getTime(),
);

const formatRelative = (dateString: string) => {
    const d = new Date(dateString);
    const now = new Date();
    const diffMs = now.getTime() - d.getTime();
    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
    if (diffDays === 0) return "Hoje";
    if (diffDays === 1) return "Ontem";
    if (diffDays < 7) return `${diffDays} dias atrás`;
    return d.toLocaleDateString("pt-BR", { day: "2-digit", month: "short" });
};
---

<DashboardLayout
    title="Notificações"
    userName={userName}
    userAvatar={userAvatar}
>
    <div class="notif-page">
        <header class="page-header">
            <div>
                <h1 class="page-title">Notificações</h1>
                <p class="subtitle">
                    Atualizações sobre suas indicações e comissões.
                </p>
            </div>
            {
                notificacoes.length > 0 && (
                    <span class="notif-count">
                        {notificacoes.length} notificações
                    </span>
                )
            }
        </header>

        {
            notificacoes.length === 0 ? (
                <div class="empty-state">
                    <div class="empty-icon">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="48"
                            height="48"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.25"
                        >
                            <>
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                            </>
                        </svg>
                    </div>
                    <h3>Tudo tranquilo por aqui!</h3>
                    <p>
                        Você não tem notificações no momento. Continue indicando
                        para gerar atividade.
                    </p>
                    <a href="/parceiro/dashboard" class="btn-cta">
                        Ver meu painel
                    </a>
                </div>
            ) : (
                <div class="notif-list">
                    {notificacoes.map((n) => (
                        <a
                            href={n.link}
                            class={`notif-item notif-${n.tipo}`}
                            aria-label={n.titulo}
                        >
                            <div class={`notif-dot dot-${n.tipo}`} />
                            <div class="notif-body">
                                <strong class="notif-title">{n.titulo}</strong>
                                <p class="notif-desc">{n.descricao}</p>
                            </div>
                            <span class="notif-time">
                                {formatRelative(n.data)}
                            </span>
                            <svg
                                class="notif-arrow"
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <polyline points="9 18 15 12 9 6" />
                            </svg>
                        </a>
                    ))}
                </div>
            )
        }
    </div>
</DashboardLayout>

<style>
    .notif-page {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
        max-width: 680px;
    }
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
    }
    .page-title {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }
    .subtitle {
        color: var(--color-subtle);
        margin-top: 0.25rem;
    }
    .notif-count {
        font-size: 0.78rem;
        font-weight: 700;
        background: var(--color-brand-primary-light);
        color: var(--color-brand-primary-dark);
        padding: 0.375rem 0.875rem;
        border-radius: var(--radius-full);
        white-space: nowrap;
        margin-top: 0.375rem;
    }

    .notif-list {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
    }
    .notif-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.125rem 1.5rem;
        border-bottom: 1px solid var(--color-border);
        text-decoration: none;
        transition: var(--transition-fast);
        color: inherit;
        min-height: 72px;
    }
    .notif-item:last-child {
        border-bottom: none;
    }
    .notif-item:hover {
        background: var(--color-bg-alt);
    }
    .notif-item:focus-visible {
        outline: 2px solid var(--color-brand-secondary);
        outline-offset: -2px;
    }

    .notif-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .dot-sucesso {
        background: #10b981;
        box-shadow: 0 0 6px rgba(16, 185, 129, 0.5);
    }
    .dot-info {
        background: #3b82f6;
        box-shadow: 0 0 6px rgba(59, 130, 246, 0.4);
    }
    .dot-alerta {
        background: #f59e0b;
        box-shadow: 0 0 6px rgba(245, 158, 11, 0.4);
    }

    .notif-body {
        flex: 1;
        min-width: 0;
    }
    .notif-title {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--color-heading);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .notif-desc {
        font-size: 0.815rem;
        color: var(--color-subtle);
        margin-top: 0.15rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .notif-time {
        font-size: 0.75rem;
        color: var(--color-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }
    .notif-arrow {
        color: var(--color-subtle);
        flex-shrink: 0;
        transition: var(--transition-fast);
    }
    .notif-item:hover .notif-arrow {
        color: var(--color-brand-secondary);
        transform: translateX(3px);
    }

    /* Empty state */
    .empty-state {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: 4rem 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
    }
    .empty-icon {
        width: 72px;
        height: 72px;
        background: var(--color-bg-alt);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-subtle);
        margin-bottom: 0.5rem;
    }
    .empty-state h3 {
        font-size: 1.125rem;
        color: var(--color-heading);
        margin: 0;
    }
    .empty-state p {
        font-size: 0.9rem;
        color: var(--color-subtle);
        max-width: 300px;
    }
    .btn-cta {
        margin-top: 0.5rem;
        padding: 0.75rem 1.75rem;
        background: var(--color-brand-secondary);
        color: #fff;
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-weight: 700;
        text-decoration: none;
        transition: var(--transition-fast);
    }
    .btn-cta:hover {
        background: var(--color-brand-secondary-dark);
        color: #fff;
    }

    @media (max-width: 600px) {
        .notif-item {
            padding: 1rem;
            gap: 0.75rem;
        }
        .page-header {
            flex-direction: column;
        }
    }
</style>
