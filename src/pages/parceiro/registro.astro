---
import { supabase as defaultSupabase } from "../../lib/supabaseClient";
import { getSupabaseServerClient } from "../../lib/supabaseSSR";
import { supabaseAdmin } from "../../lib/supabaseAdmin";
import {
    sanitizePhone,
    isValidPhone,
    sanitizeCPF,
    isValidCPF,
} from "../../utils/validation";
import { logError } from "../../utils/logger";
import { captacaoService } from "../../services/captacaoService";
import { partnerService } from "../../services/partnerService";

let MAIN_TENANT_ID = import.meta.env.PUBLIC_MAIN_TENANT_ID;
let errorMessage = "";

// Lê o grupo de captação vindo dos query params (/grupo/[slug] -> /parceiro/registro?grupo_id=...)
const grupoIdParam = Astro.url.searchParams.get("grupo_id") || "";
const grupoSlugParam = Astro.url.searchParams.get("grupo_slug") || "";
const refSlug = Astro.url.searchParams.get("ref") || "";

let effectiveGrupoId = grupoIdParam;
let captacaoContexto = null;

// 1. Prioridade: Link direto de Grupo (/grupo/[slug])
if (grupoSlugParam) {
    captacaoContexto = await captacaoService.getCaptacaoContext(grupoSlugParam);
    if (captacaoContexto) {
        effectiveGrupoId = captacaoContexto.grupoId;
    }
} 
// 2. Segunda prioridade: Link de recrutamento de outro parceiro (/ref/[slug])
else if (refSlug) {
    const parentPartner = await partnerService.getPartnerBySlug(refSlug);
    if (parentPartner?.grupo_id) {
        effectiveGrupoId = parentPartner.grupo_id;
        // Busca o contexto do grupo para exibir na UI bonita
        const { data: groupData } = await supabaseAdmin
            .from('grupos_parceiros')
            .select('*')
            .eq('id', effectiveGrupoId)
            .single();
        
        if (groupData) {
            captacaoContexto = {
                grupoId: groupData.id,
                grupoNome: groupData.nome,
                grupoSlug: groupData.slug,
                grupoDescricao: groupData.descricao,
                tipoRemuneracao: groupData.tipo_remuneracao,
                valorRecompensa: groupData.valor_recompensa,
                tenantId: groupData.tenant_id
            };
        }
    }
}

// Bloqueio de cadastro orgânico (sem link de convite)
const hasValidInvite = !!effectiveGrupoId;
if (!hasValidInvite && Astro.request.method !== "POST") {
    errorMessage = "Acesso restrito: Você precisa de um link de convite válido (de um grupo ou parceiro) para se cadastrar no sistema.";
}

try {
    if (!MAIN_TENANT_ID) {
        const { data: firstAdmin } = await supabaseAdmin
            .from("profiles")
            .select("tenant_id")
            .eq("tipo_usuario", "admin")
            .limit(1)
            .maybeSingle();
        MAIN_TENANT_ID = firstAdmin?.tenant_id ?? "4a254f52-99bd-43dd-86e2-ec031206077a";
    }
} catch (globalError) {
    console.error("[REGISTRO_INIT_ERROR]", globalError);
    errorMessage = "Erro de inicialização do sistema.";
}

if (Astro.request.method === "POST") {
    let emailAddress = "não_identificado";
    try {
        const data = await Astro.request.formData();
        const nome = data.get("nome")?.toString() || "";
        const email = data.get("email")?.toString() || "";
        emailAddress = email;
        const whatsapp = data.get("whatsapp")?.toString() || "";
        const password = data.get("password")?.toString() || "";
        const rawCpf = data.get("cpf")?.toString() || "";
        // grupo_id vem do campo hidden do formulário (preenchido pelos query params via /grupo/[slug])
        const grupoId = data.get("grupo_id")?.toString() || null;
        const formTenantId = data.get("tenant_id")?.toString() || MAIN_TENANT_ID;
        const action = data.get("action")?.toString();

        if (action === "oauth_google") {
            const host = Astro.request.headers.get("host") || Astro.url.host;
            const protocol = Astro.request.headers.get("x-forwarded-proto") || (Astro.url.protocol.replace(':', '') || 'https');
            const origin = `${protocol}://${host}`;

            const supabaseSSR = getSupabaseServerClient(Astro.cookies);

            let callbackUrl = `${origin}/api/auth/callback?next=/parceiro/dashboard`;
            if (grupoId) callbackUrl += `&grupo_id=${grupoId}`;
            if (formTenantId) callbackUrl += `&tenant_id=${formTenantId}`;

            const { data: authData, error } = await supabaseSSR.auth.signInWithOAuth({
                provider: "google",
                options: {
                    redirectTo: callbackUrl,
                },
            });

            if (error) {
                logError("[AUTH_OAUTH_ERROR]", error);
                errorMessage = "Erro ao conectar com Google: " + error.message;
            } else if (authData?.url) {
                return Astro.redirect(authData.url);
            } else {
                errorMessage = "Não foi possível gerar o link de autenticação do Google.";
            }
        } else {
            const cleanWhatsapp = sanitizePhone(whatsapp);
            const cleanCpf = sanitizeCPF(rawCpf);

        if (!email || !password || !nome) {
            errorMessage = "Por favor, preencha todos os campos obrigatórios.";
        } else if (whatsapp && !isValidPhone(whatsapp)) {
            errorMessage = "Telefone inválido. Verifique o DDD e os números.";
        } else if (rawCpf && !isValidCPF(rawCpf)) {
            errorMessage =
                "O CPF digitado é inválido. A formatação com pontos e traços é opcional, mas os números devem existir de verdade (dígito verificador incorreto).";
        } else {
            const supabaseSSR = getSupabaseServerClient(Astro.cookies);
            // Cria a conta do usuário
            const { data: authData, error: authError } =
                await supabaseSSR.auth.signUp({
                    email: emailAddress,
                    password,
                    options: {
                        data: { 
                            full_name: nome, 
                            phone: cleanWhatsapp,
                            tenant_id: formTenantId // Injeta no JWT para o Trigger de Auth
                        },
                    },
                });

            if (authError) {
                logError("[AUTH_ERROR] Cadastro falhou no Supabase Auth", {
                    email: emailAddress,
                    authError,
                });
                if (
                    authError.message?.includes("invalid input") ||
                    authError.message?.includes("format") ||
                    authError.message?.includes("syntax")
                ) {
                    errorMessage =
                        "Não foi possível concluir o cadastro. Verifique seus dados e tente novamente.";
                } else {
                    errorMessage = authError.message;
                }
            } else if (authData.user) {
                // Insere o profile manual usando admin com o tenant correto do recrutador
                const { error: profileError } = await supabaseAdmin
                    .from("profiles")
                    .insert({
                        id: authData.user.id,
                        tenant_id: formTenantId,
                        nome: nome,
                        email: emailAddress,
                        telefone: cleanWhatsapp,
                        cpf: cleanCpf,
                        tipo_usuario: "parceiro",
                        grupo_id: grupoId,
                        status: 'ativo' // Cadastro via link direto/recrutamento já entra ativo
                    });

                if (profileError) {
                    logError("[DB_ERROR] Erro ao criar perfil", {
                        userId: authData.user.id,
                        profileError,
                    });
                    // continua mesmo com erro pra tentar logar
                }

                if (authData.session) {
                    return Astro.redirect("/sucesso");
                } else {
                    errorMessage =
                        "Confirmação de e-mail está ativada no Supabase. Por favor, desative 'Confirm email' nas configurações ou verifique sua caixa de entrada.";
                }
            }
        }
        }
    } catch (error) {
        if (error instanceof Error) {
            logError(
                "[SYSTEM_ERROR] Falha inesperada durante o registro",
                { email: emailAddress },
                error,
            );
            if (error.message.includes("Content-Type was not one of")) {
                errorMessage =
                    "Erro de conexão segura. O navegador falhou ao enviar os dados do formulário corretamente.";
            } else {
                errorMessage = error.message;
            }
        } else {
            logError("[SYSTEM_ERROR] Erro desconhecido durante o registro", {
                email: emailAddress,
                error,
            });
            errorMessage = "Erro desconhecido";
        }
    }
}
---

<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastro Mágico - Parceiro | Assina Comigo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="/src/styles/global.css" />
    <style>
        body { margin: 0; min-height: 100vh; display: flex; font-family: 'Inter', sans-serif; background-color: var(--color-bg-base); }
        .split-layout { display: flex; min-height: 100vh; width: 100%; }
        .split-left { flex: 1; background: linear-gradient(135deg, var(--color-bg-dark) 0%, #1a0033 100%); display: flex; flex-direction: column; justify-content: center; padding: 4rem; color: #fff; position: relative; overflow: hidden; }
        .split-right { width: 50%; max-width: 600px; background: var(--color-surface); display: flex; flex-direction: column; justify-content: center; padding: 4rem; position: relative; box-shadow: -20px 0 50px rgba(0,0,0,0.05); }
        .auth-container { max-width: 420px; margin: 0 auto; width: 100%; }
        h1 { font-family: 'Outfit', sans-serif; font-size: 3.5rem; font-weight: 800; line-height: 1.1; margin-bottom: 1.5rem; letter-spacing: -0.03em; }
        h1 span { color: var(--color-brand-secondary); }
        .subtitle { font-size: 1.25rem; line-height: 1.6; color: rgba(255, 255, 255, 0.8); max-width: 80%; }
        .brand-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); padding: 0.5rem 1rem; border-radius: 100px; font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 0.875rem; color: var(--color-brand-secondary); margin-bottom: 2rem; backdrop-filter: blur(8px); align-self: flex-start; }
        .auth-header h2 { font-family: 'Outfit', sans-serif; font-size: 2rem; font-weight: 800; color: var(--color-heading); margin: 0 0 0.5rem 0; letter-spacing: -0.02em; }
        .auth-header p { color: var(--color-subtle); margin: 0 0 2rem 0; }
        .btn-google { width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 0.875rem; background: white; border: 1px solid var(--color-border); border-radius: var(--radius-lg); font-weight: 600; cursor: pointer; transition: all 0.2s; margin-bottom: 1.5rem; color: var(--color-heading); font-family: 'Inter', sans-serif;}
        .btn-google:hover { background: #f8fafc; border-color: #cbd5e1; }
        .btn-google img { width: 20px; height: 20px; }
        .divider { display: flex; align-items: center; text-align: center; margin-bottom: 1.5rem; color: var(--color-subtle); }
        .divider::before, .divider::after { content: ''; flex: 1; border-bottom: 1px solid var(--color-border); }
        .divider span { padding: 0 1rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; }
        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; font-size: 0.875rem; font-weight: 600; color: var(--color-heading); margin-bottom: 0.5rem; }
        .input-wrapper { position: relative; }
        .input-wrapper .material-symbols-outlined { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--color-subtle); pointer-events: none; }
        .form-control { box-sizing: border-box; width: 100%; padding: 0.875rem 1rem 0.875rem 2.75rem; font-family: 'Inter', sans-serif; font-size: 1rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); transition: all 0.2s; color: var(--color-heading); }
        .form-control:focus { outline: none; border-color: var(--color-brand-primary); box-shadow: 0 0 0 4px rgba(96,40,255,0.1); }
        .btn-submit { width: 100%; padding: 1rem; background: var(--color-brand-primary); color: white; border: none; border-radius: var(--radius-lg); font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-top: 1rem; }
        .btn-submit:hover { background: var(--color-brand-primary-dark); transform: translateY(-2px); }
        .alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: 1rem; border-radius: var(--radius-lg); display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 1.5rem; font-size: 0.875rem; }
        @media (max-width: 1024px) { 
            .split-left { display: none; } 
            .split-right { width: 100%; max-width: none; padding: 2rem; box-shadow: none; }
            .auth-header h2 { font-size: 1.75rem; }
        }
    </style>
</head>
<body>
    <div class="split-layout">
        <div class="split-left">
            <div class="brand-badge"><span class="material-symbols-outlined">bolt</span> Ligeira Premium</div>
            <h1>Transforme contatos em <span>renda extra.</span></h1>
            <p class="subtitle">Junte-se ao programa Assina Comigo e seja recompensado por cada nova assinatura gerada através da sua indicação.</p>
        </div>
        <div class="split-right">
            <div class="auth-container">
                <div class="auth-header">
                    <h2>Crie sua conta</h2>
                    <p>Preencha os dados e libere seu painel mágico.</p>
                </div>

                {errorMessage && (
                    <div class="alert-error">
                        <span class="material-symbols-outlined">error</span>
                        <span>{errorMessage}</span>
                    </div>
                )}

                {!hasValidInvite ? (
                    <div style="text-align: center; padding: 2.5rem 1.5rem; background: var(--color-bg-base); border: 2px dashed var(--color-border); border-radius: var(--radius-2xl);">
                        <span class="material-symbols-outlined" style="font-size: 3rem; color: var(--color-subtle);">lock_person</span>
                        <h3 style="margin: 1rem 0 0.5rem; font-family: 'Outfit'; color: var(--color-heading);">Acesso Restrito</h3>
                        <p style="color: var(--color-subtle); font-size: 0.875rem; margin-bottom: 1.5rem;">Você precisa do link de convite de um parceiro para se cadastrar.</p>
                        <a href="/" style="color: var(--color-brand-primary); font-weight: 600; text-decoration: none;">&larr; Voltar para a Home</a>
                    </div>
                ) : (
                    <>
                        {captacaoContexto && (
                            <div style="background: linear-gradient(to right, rgba(96,40,255,0.05), rgba(96,40,255,0.02)); border: 1px solid rgba(96,40,255,0.1); border-radius: var(--radius-xl); padding: 1rem; display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
                                <div style="width:48px; height:48px; background:rgba(96,40,255,0.1); color:var(--color-brand-primary); border-radius:var(--radius-lg); display:flex; align-items:center; justify-content:center; font-size:1.5rem;">
                                    {captacaoContexto.tipoRemuneracao === 'pontos' ? '🏆' : '💰'}
                                </div>
                                <div>
                                    <p style="margin:0; font-size:0.7rem; font-weight:700; text-transform:uppercase; color:var(--color-subtle);">Convite Recebido</p>
                                    <p style="margin:0; font-family:'Outfit'; font-size:1.1rem; font-weight:800; color:var(--color-heading);">{captacaoContexto.grupoNome}</p>
                                </div>
                            </div>
                        )}
                        <form method="POST">
                            <input type="hidden" name="action" value="oauth_google" />
                            <input type="hidden" name="grupo_id" value={effectiveGrupoId} />
                            <input type="hidden" name="tenant_id" value={captacaoContexto?.tenantId || MAIN_TENANT_ID} />
                            <button type="submit" class="btn-google">
                                <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google Logo" />
                                Cadastrar com Google
                            </button>
                        </form>
                        
                        <div class="divider"><span>ou crie com e-mail</span></div>

                        <form method="POST" enctype="application/x-www-form-urlencoded">
                            <div class="form-group">
                                <label for="nome">Nome completo</label>
                                <div class="input-wrapper">
                                    <span class="material-symbols-outlined">person</span>
                                    <input class="form-control" id="nome" name="nome" placeholder="Seu nome" type="text" required />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="email">E-mail</label>
                                <div class="input-wrapper">
                                    <span class="material-symbols-outlined">mail</span>
                                    <input class="form-control" id="email" name="email" placeholder="seu@email.com" type="email" required />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="whatsapp">WhatsApp</label>
                                <div class="input-wrapper">
                                    <span class="material-symbols-outlined">phone_iphone</span>
                                    <input class="form-control" id="whatsapp" name="whatsapp" placeholder="(00) 00000-0000" type="tel" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="cpf">CPF <span style="font-weight:400; color:var(--color-subtle);">(Opcional)</span></label>
                                <div class="input-wrapper">
                                    <span class="material-symbols-outlined">badge</span>
                                    <input class="form-control" id="cpf" name="cpf" placeholder="000.000.000-00" type="text" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="password">Crie sua senha</label>
                                <div class="input-wrapper">
                                    <span class="material-symbols-outlined">lock</span>
                                    <input class="form-control" id="password" name="password" placeholder="Mínimo 6 caracteres" type="password" required />
                                </div>
                            </div>
                            
                            <input type="hidden" name="grupo_id" value={effectiveGrupoId} />
                            <input type="hidden" name="tenant_id" value={captacaoContexto?.tenantId || MAIN_TENANT_ID} />
                            
                            <button class="btn-submit" type="submit">
                                Concluir Cadastro 
                                <span class="material-symbols-outlined">arrow_forward</span>
                            </button>
                            <p style="font-size: 0.75rem; color: var(--color-subtle); text-align: center; margin-top: 1rem;">
                                Ao se cadastrar, você concorda com nossos Termos de Uso.
                            </p>
                        </form>
                    </>
                )}
                
                <div style="margin-top:2rem; text-align:center; font-size:0.875rem; color:var(--color-subtle);">
                    Já é parceiro? <a href="/parceiro/login" style="color:var(--color-brand-primary); font-weight:600; text-decoration:none;">Entrar na conta</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
