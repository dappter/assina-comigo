---
const params = new URLSearchParams();
params.set("mode", "register");

const grupoId = Astro.url.searchParams.get("grupo_id");
const grupoSlug = Astro.url.searchParams.get("grupo_slug");

if (grupoId) params.set("grupo_id", grupoId);
if (grupoSlug) params.set("grupo_slug", grupoSlug);

return Astro.redirect(`/?${params.toString()}#signup`);
