---
import { supabase } from "../../lib/supabaseClient";

// Tela gerada a partir do Design System e UI do Stitch

let errorMessage = "";
let successMessage = "";
let emailAddress = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();

    const action = data.get("action");
    const contact = data.get("contact")?.toString();

    if (action === "login_password") {
      emailAddress = contact || "";
      const password = data.get("password")?.toString();

      if (!emailAddress || !emailAddress.includes("@") || !password) {
        errorMessage = "Por favor, insira um e-mail válido e uma senha.";
      } else {
        const { data: sessionData, error } =
          await supabase.auth.signInWithPassword({
            email: emailAddress,
            password: password,
          });

        if (error || !sessionData.session) {
          errorMessage = error?.message || "E-mail ou senha incorretos.";
        } else {
          const { access_token, refresh_token } = sessionData.session;
          Astro.cookies.set("sb-access-token", access_token, {
            path: "/",
            secure: import.meta.env.PROD,
            httpOnly: true,
            sameSite: "lax",
          });
          Astro.cookies.set("sb-refresh-token", refresh_token, {
            path: "/",
            secure: import.meta.env.PROD,
            httpOnly: true,
            sameSite: "lax",
          });
          return Astro.redirect("/parceiro/dashboard");
        }
      }
    } else if (action === "oauth_google") {
      const { data: authData, error } = await supabase.auth.signInWithOAuth({
        provider: "google",
        options: {
          redirectTo: `${Astro.url.origin}/api/auth/callback`,
        },
      });
      if (error) {
        errorMessage = error.message;
      } else if (authData.url) {
        return Astro.redirect(authData.url);
      }
    }
  } catch (error) {
    if (error instanceof Error) {
      if (error.message.includes("Content-Type was not one of")) {
        errorMessage =
          "Erro de conexão segura. O navegador falhou ao enviar os dados do formulário corretamente.";
      } else {
        errorMessage = error.message;
      }
    } else {
      errorMessage = "Ocorreu um erro inesperado.";
    }
  }
}
---

<!doctype html>
<html class="light" lang="pt-br">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login do Parceiro - Assina Comigo</title>
    <script
      is:inline
      src="https://cdn.tailwindcss.com?plugins=forms,container-queries"
    ></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#FFB918", // Vibrant Yellow
              secondary: "#0062FF", // Action Blue
              "background-light": "#F8FAFC",
              "background-dark": "#0F172A",
            },
            fontFamily: {
              display: ["Inter", "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "8px",
            },
          },
        },
      };

      // Handle Dark Mode preference
      if (
        typeof window !== "undefined" &&
        window.matchMedia &&
        window.matchMedia("(prefers-color-scheme: dark)").matches
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>
    <style>
      body {
        font-family: "Inter", sans-serif;
        -webkit-tap-highlight-color: transparent;
        min-height: max(884px, 100dvh);
      }
      .ios-shadow {
        box-shadow:
          0 4px 6px -1px rgba(0, 0, 0, 0.05),
          0 2px 4px -1px rgba(0, 0, 0, 0.03);
      }
    </style>
  </head>
  <body
    class="bg-gradient-to-br from-[#e0f2fe] to-[#f8fafc] dark:from-slate-900 dark:to-slate-950 min-h-screen flex flex-col items-center justify-start p-6"
  >
    <div class="h-12 w-full"></div>
    <div class="w-full max-w-sm flex flex-col items-center mb-12">
      <div
        class="w-16 h-16 bg-secondary rounded-2xl flex items-center justify-center mb-4 ios-shadow shadow-[0_0_35px_rgba(0,98,255,0.4)] relative"
      >
        <span class="material-symbols-outlined text-white text-4xl"
          >handshake</span
        >
      </div>
      <h1 class="text-2xl font-bold text-blue-950 dark:text-white text-center">
        Assina Comigo
      </h1>
      <p class="text-blue-800/70 dark:text-slate-400 text-sm mt-1 font-medium">
        Gestão de Indicações ISP
      </p>
    </div>
    <main
      class="w-full max-w-sm bg-white/90 backdrop-blur-sm dark:bg-slate-800 rounded-3xl p-8 ios-shadow border border-white/50"
    >
      <div class="mb-8">
        <h2 class="text-xl font-bold text-blue-950 dark:text-white">
          Entrar como parceiro
        </h2>
        <p class="text-blue-800/70 dark:text-slate-400 text-sm mt-2">
          Acesse sua conta para visualizar seu dashboard.
        </p>
      </div>

      {
        errorMessage && (
          <div class="mb-6 p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-xl text-red-600 dark:text-red-400 text-sm text-center font-medium">
            {errorMessage === "Invalid login credentials"
              ? "E-mail ou senha inválidos."
              : errorMessage}
          </div>
        )
      }

      {
        successMessage && (
          <div class="mb-6 p-4 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-xl text-green-600 dark:text-green-400 text-sm text-center font-medium">
            {successMessage}
          </div>
        )
      }

      <div class="mt-8">
        <form
          method="POST"
          class="mb-6"
          enctype="application/x-www-form-urlencoded"
        >
          <input type="hidden" name="action" value="oauth_google" />
          <button
            type="submit"
            class="w-full flex items-center justify-center gap-3 py-3.5 px-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm hover:shadow-md hover:bg-slate-50 dark:hover:bg-slate-800 transition-all font-bold text-slate-700 dark:text-slate-300 group"
          >
            <img
              src="https://www.svgrepo.com/show/475656/google-color.svg"
              alt="Google Logo"
              class="w-5 h-5 group-hover:scale-110 transition-transform"
            />
            Continuar com o Google
          </button>
        </form>

        <div class="relative flex py-2 items-center mb-6">
          <div
            class="flex-grow border-t border-slate-200 dark:border-slate-700"
          >
          </div>
          <span
            class="flex-shrink-0 mx-4 text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest"
          >
            ou use link mágico
          </span>
          <div
            class="flex-grow border-t border-slate-200 dark:border-slate-700"
          >
          </div>
        </div>

        <div
          class="flex p-1 bg-blue-50/50 dark:bg-slate-700 rounded-xl mb-8 border border-blue-100/50"
        >
          <button
            type="button"
            class="flex-1 flex items-center justify-center gap-2 py-2.5 text-sm font-semibold rounded-lg transition-all text-blue-800/60 dark:text-slate-400 hover:text-blue-950 dark:hover:text-slate-200"
            id="btn-whatsapp"
            onclick="alert('Login por WhatsApp será liberado na Fase 2.');"
          >
            <span class="material-symbols-outlined text-lg text-green-500">
              chat
            </span>
            WhatsApp
          </button>
          <button
            type="button"
            class="flex-1 flex items-center justify-center gap-2 py-2.5 text-sm font-semibold rounded-lg transition-all bg-white dark:bg-slate-600 text-blue-950 dark:text-white shadow-sm"
            id="btn-email"
          >
            <span class="material-symbols-outlined text-lg">mail</span>
            E-mail
          </button>
        </div>

        <form
          class="space-y-6"
          method="POST"
          enctype="application/x-www-form-urlencoded"
        >
          <input type="hidden" name="action" value="login_password" />
          <div class="space-y-4">
            <div>
              <label
                class="block text-xs font-bold uppercase tracking-wider text-blue-900/60 dark:text-slate-500 mb-2 ml-1"
                for="contact"
              >
                Seu E-mail
              </label>
              <input
                class="w-full px-4 py-4 bg-white dark:bg-slate-900 border border-blue-100 dark:border-slate-700 rounded-xl text-blue-950 dark:text-white placeholder-blue-900/30 focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition-all shadow-sm"
                id="contact"
                name="contact"
                placeholder="exemplo@email.com.br"
                type="email"
                required
              />
            </div>
            <div>
              <label
                class="block text-xs font-bold uppercase tracking-wider text-blue-900/60 dark:text-slate-500 mb-2 ml-1"
                for="password"
              >
                Sua Senha
              </label>
              <input
                class="w-full px-4 py-4 bg-white dark:bg-slate-900 border border-blue-100 dark:border-slate-700 rounded-xl text-blue-950 dark:text-white placeholder-blue-900/30 focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition-all shadow-sm"
                id="password"
                name="password"
                placeholder="Sua senha secreta"
                type="password"
                required
              />
            </div>
          </div>
          <button
            class="w-full bg-gradient-to-r from-yellow-400 to-primary hover:from-yellow-300 hover:to-yellow-400 active:scale-[0.98] transition-all text-blue-950 font-bold py-4 rounded-xl shadow-lg shadow-primary/30 flex items-center justify-center gap-2"
            type="submit"
          >
            Entrar
            <span class="material-symbols-outlined">login</span>
          </button>
        </form>
      </div>

      <div
        class="mt-8 pt-8 border-t border-blue-100 dark:border-slate-700 text-center"
      >
        <p class="text-sm text-blue-800/70 dark:text-slate-400">
          Ainda não é um parceiro?
          <a
            class="text-secondary font-bold hover:underline"
            href="/parceiro/registro">Solicitar adesão agora</a
          >
        </p>
      </div>
    </main>
    <footer class="mt-auto py-8 text-center">
      <button
        class="flex items-center justify-center gap-2 text-blue-800/60 dark:text-slate-500 text-sm font-semibold hover:text-secondary transition-colors"
      >
        <span class="material-symbols-outlined text-lg">help</span>
        Preciso de ajuda para acessar
      </button>
    </footer>
  </body>
</html>
