---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { partnerService } from "../../services/partnerService";

const tenantId = Astro.locals.tenantId;
const profileId = Astro.locals.profileId;

if (!tenantId || !profileId) {
    return Astro.redirect("/parceiro/login");
}

const partner = await partnerService.getPartnerById(tenantId, profileId);
const userName = partner?.nome || "Parceiro";
const userAvatar = userName.substring(0, 2).toUpperCase();
const referralLink = `${Astro.url.origin}/ref/${profileId}`;
---

<DashboardLayout title="Meu Perfil" userName={userName} userAvatar={userAvatar}>
    <div class="perfil-page">
        <!-- Hero do Perfil -->
        <div class="perfil-hero">
            <div class="hero-bg"></div>
            <div class="hero-content">
                <div class="avatar-ring">
                    <div class="avatar-big">{userAvatar}</div>
                </div>
                <div class="hero-info">
                    <h1 class="hero-name">{userName}</h1>
                    <span class="hero-badge">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            ><polygon
                                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
                            ></polygon></svg
                        >
                        Parceiro Ativo
                    </span>
                </div>
            </div>
        </div>

        <div class="perfil-body">
            <!-- Meu Link -->
            <section class="info-card link-card">
                <h2 class="card-title">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><path
                            d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                        ></path><path
                            d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                        ></path></svg
                    >
                    Meu Link de Indicação
                </h2>
                <p class="card-desc">
                    Compartilhe este link para gerar novas indicações e
                    comissões.
                </p>
                <div class="link-box">
                    <span class="link-text" id="partnerLink"
                        >{referralLink}</span
                    >
                    <button
                        class="copy-link-btn"
                        id="copyLinkBtn"
                        title="Copiar link"
                        aria-label="Copiar link de indicação"
                    >
                        <svg
                            id="copyIcon"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><rect
                                width="14"
                                height="14"
                                x="8"
                                y="8"
                                rx="2"
                                ry="2"></rect><path
                                d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                            ></path></svg
                        >
                    </button>
                </div>
                <div class="link-actions">
                    <a
                        href={`https://wa.me/?text=${encodeURIComponent(`Olá! Faça seu cadastro como cliente pela minha indicação: ${referralLink}`)}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-wa"
                        aria-label="Compartilhar via WhatsApp"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                            ></path></svg
                        >
                        Compartilhar no WhatsApp
                    </a>
                </div>
            </section>

            <!-- Dados pessoais -->
            <section class="info-card data-card">
                <h2 class="card-title">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                        ></path><circle cx="12" cy="7" r="4"></circle></svg
                    >
                    Dados do Parceiro
                </h2>
                <div class="data-fields">
                    <div class="field-row">
                        <span class="field-label">Nome completo</span>
                        <span class="field-value">{userName}</span>
                    </div>
                    <div class="field-row">
                        <span class="field-label">ID do parceiro</span>
                        <span class="field-value field-mono"
                            >{profileId?.slice(0, 16)}...</span
                        >
                    </div>
                    <div class="field-row">
                        <span class="field-label">Status</span>
                        <span class="status-chip active">Ativo</span>
                    </div>
                </div>
                <a
                    href="/parceiro/configuracoes"
                    class="btn-config"
                    aria-label="Ir para configurações"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><circle cx="12" cy="12" r="3"></circle><path
                            d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33 1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82 1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
                        ></path></svg
                    >
                    Editar configurações
                </a>
            </section>
        </div>
    </div>

    <script>
        const copyBtn = document.getElementById("copyLinkBtn");
        const linkEl = document.getElementById("partnerLink");
        const copyIcon = document.getElementById("copyIcon");

        copyBtn?.addEventListener("click", async () => {
            const text = linkEl?.textContent || "";
            try {
                await navigator.clipboard.writeText(text);
                if (copyIcon) {
                    copyIcon.innerHTML = `<polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"></polyline>`;
                    copyIcon.style.color = "#10b981";
                }
                setTimeout(() => {
                    if (copyIcon) {
                        copyIcon.innerHTML = `<rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>`;
                        copyIcon.style.color = "";
                    }
                }, 2000);
            } catch {
                alert("Não foi possível copiar. Copie manualmente: " + text);
            }
        });
    </script>
</DashboardLayout>

<style>
    .perfil-page {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
        max-width: 720px;
    }

    /* Hero */
    .perfil-hero {
        position: relative;
        border-radius: var(--radius-2xl);
        overflow: hidden;
        background: #0f172a;
        padding: 2.5rem 2rem;
        color: #fff;
    }
    .hero-bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #0052ff 0%, #0f172a 60%);
        opacity: 0.9;
    }
    .hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }
    .avatar-ring {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(255, 185, 24, 0.2);
        border: 3px solid var(--color-brand-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 0 20px rgba(255, 185, 24, 0.3);
    }
    .avatar-big {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: var(--color-brand-primary);
        color: #111827;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 900;
        font-family: "Outfit", sans-serif;
    }
    .hero-name {
        color: #fff;
        font-size: 1.75rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.02em;
    }
    .hero-badge {
        margin-top: 0.5rem;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--color-brand-primary);
        background: rgba(255, 185, 24, 0.15);
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-full);
        border: 1px solid rgba(255, 185, 24, 0.3);
    }

    /* Cards */
    .perfil-body {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }
    .info-card {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        box-shadow: var(--shadow-sm);
    }
    .card-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--color-heading);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
    }
    .card-desc {
        font-size: 0.875rem;
        color: var(--color-subtle);
        margin: 0;
        line-height: 1.5;
    }

    /* Link box */
    .link-box {
        display: flex;
        align-items: center;
        background: var(--color-bg-base);
        border: 1.5px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
        padding: 0.625rem 0.625rem 0.625rem 1rem;
        gap: 0.75rem;
    }
    .link-text {
        flex: 1;
        font-size: 0.815rem;
        font-family: "Courier New", monospace;
        color: var(--color-brand-secondary);
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .copy-link-btn {
        width: 36px;
        height: 36px;
        background: var(--color-bg-alt);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-body);
        flex-shrink: 0;
        transition: var(--transition-fast);
    }
    .copy-link-btn:hover {
        background: var(--color-brand-primary);
        color: #111;
    }
    .copy-link-btn:focus-visible {
        outline: 2px solid var(--color-brand-secondary);
    }
    .link-actions {
        display: flex;
        gap: 0.75rem;
    }
    .btn-wa {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #25d366;
        color: #fff;
        padding: 0.75rem 1.25rem;
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-weight: 700;
        text-decoration: none;
        transition: var(--transition-fast);
        box-shadow: 0 4px 12px rgba(37, 211, 102, 0.2);
    }
    .btn-wa:hover {
        background: #1eb957;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(37, 211, 102, 0.3);
        color: #fff;
    }

    /* Dados */
    .data-fields {
        display: flex;
        flex-direction: column;
        gap: 0;
    }
    .field-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--color-border);
        gap: 1rem;
    }
    .field-row:last-child {
        border-bottom: none;
    }
    .field-label {
        font-size: 0.8rem;
        color: var(--color-subtle);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .field-value {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-heading);
        text-align: right;
    }
    .field-mono {
        font-family: "Courier New", monospace;
        font-size: 0.78rem;
        color: var(--color-body);
    }
    .status-chip {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-full);
    }
    .status-chip.active {
        background: #d1fae5;
        color: #065f46;
    }
    .btn-config {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-brand-secondary);
        text-decoration: none;
        padding: 0.625rem 0;
        border-top: 1px solid var(--color-border);
        margin-top: auto;
        transition: var(--transition-fast);
    }
    .btn-config:hover {
        gap: 0.75rem;
    }

    @media (max-width: 768px) {
        .hero-content {
            flex-direction: column;
            text-align: center;
        }
        .hero-name {
            font-size: 1.4rem;
        }
        .perfil-body {
            grid-template-columns: 1fr;
        }
        .avatar-ring {
            width: 72px;
            height: 72px;
        }
        .avatar-big {
            width: 56px;
            height: 56px;
            font-size: 1.25rem;
        }
    }
</style>
