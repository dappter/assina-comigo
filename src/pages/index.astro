---
import raioLogo from "../assets/icons/RAIO.png";
import faviconIco from "../assets/icons/favicon.ico";
import favicon16 from "../assets/icons/favicon-16x16.png";
import favicon32 from "../assets/icons/favicon-32x32.png";
import appleTouchIcon from "../assets/icons/apple-touch-icon.png";
import android192 from "../assets/icons/android-chrome-192x192.png";
import android512 from "../assets/icons/android-chrome-512x512.png";
import logoLigeiraHorizontal from "../assets/branding/LOGO LIGEIRA HORIZONTAL COM ADESIVO 2026.png";
import ligiaHeroImage from "../assets/branding/LIGIA LP ASSINA COMIGO.png";
import { getSupabaseServerClient } from "../lib/supabaseSSR";
import { supabaseAdmin } from "../lib/supabaseAdmin";
import { captacaoService } from "../services/captacaoService";
import { logger } from "../utils/logger";
import { mapSupabaseAuthErrorMessage } from "../utils/authErrors";
import { formatCPFDisplay, formatPhoneDisplay, sanitizePhone, isValidWhatsApp } from "../utils/validation";

let errorMessage = "";
let successMessage = "";
const requestedMode = Astro.url.searchParams.get("mode");
let activeMode: "login" | "register" = requestedMode === "login" ? "login" : "register";

let formNome = "";
let formEmail = "";
let formWhatsapp = "";
let formCpf = "";

const grupoSlugParam = (Astro.url.searchParams.get("grupo_slug") || "").trim();
const grupoIdParam = (Astro.url.searchParams.get("grupo_id") || "").trim();

let effectiveGrupoId = grupoIdParam;
let effectiveTenantId = import.meta.env.PUBLIC_MAIN_TENANT_ID;

if (!effectiveTenantId) {
    console.error("[CONFIG_ERROR] PUBLIC_MAIN_TENANT_ID não definido no arquivo .env");
    // Em desenvolvimento, podemos usar um valor de segurança caso o .env não tenha carregado
    if (import.meta.env.DEV) {
        effectiveTenantId = "4a254f52-99bd-43dd-86e2-ec031206077a";
    }
}
let captacaoContexto: Awaited<ReturnType<typeof captacaoService.getCaptacaoContext>> = null;

if (grupoSlugParam) {
    captacaoContexto = await captacaoService.getCaptacaoContext(grupoSlugParam);
    if (captacaoContexto) {
        effectiveGrupoId = captacaoContexto.grupoId;
        effectiveTenantId = captacaoContexto.tenantId;
    } else {
        errorMessage = "Link de grupo inválido ou expirado. Solicite um novo link para cadastro.";
    }
} else if (effectiveGrupoId) {
    const { data: groupData } = await supabaseAdmin
        .from("grupos_parceiros")
        .select("id, nome, slug, descricao, tipo_remuneracao, valor_recompensa, tenant_id")
        .eq("id", effectiveGrupoId)
        .maybeSingle();

    if (groupData) {
        captacaoContexto = {
            grupoId: groupData.id,
            grupoNome: groupData.nome,
            grupoSlug: groupData.slug,
            grupoDescricao: groupData.descricao,
            tipoRemuneracao: groupData.tipo_remuneracao,
            valorRecompensa: groupData.valor_recompensa,
            tenantId: groupData.tenant_id,
        };
        effectiveTenantId = groupData.tenant_id;
    }
}

if (!requestedMode && !effectiveGrupoId) {
    activeMode = "login";
}

const googleError = Astro.url.searchParams.get("error");
const googleMessage = Astro.url.searchParams.get("message");
if (googleError === "oauth_error") {
    errorMessage = googleMessage ? `Erro do Google: ${decodeURIComponent(googleMessage)}` : "Erro interno ao iniciar acesso ao Google.";
}

if (!effectiveGrupoId) {
    const { data: defaultGroup } = await supabaseAdmin
        .from("grupos_parceiros")
        .select("id")
        .eq("tenant_id", effectiveTenantId)
        .ilike("nome", "%Ligeira%")
        .maybeSingle();

    if (defaultGroup) {
        effectiveGrupoId = defaultGroup.id;
    }
}

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const action = data.get("action")?.toString() || "";
    const modeField = data.get("mode")?.toString() === "login" ? "login" : "register";
    activeMode = modeField;

    const formGrupoId = data.get("grupo_id")?.toString() || effectiveGrupoId;
    const formTenantId = data.get("tenant_id")?.toString() || effectiveTenantId;

    if (action === "login_password") {
        const email = (data.get("email")?.toString() || "").trim().toLowerCase();
        const password = data.get("password")?.toString() || "";

        if (!email || !email.includes("@") || !password || password.length < 6) {
            errorMessage = "Informe um e-mail válido e uma senha com no mínimo 6 caracteres.";
        } else {
            const supabaseSSR = getSupabaseServerClient(Astro.cookies);
            const { data: sessionData, error } = await supabaseSSR.auth.signInWithPassword({ email, password });

            if (error || !sessionData.session) {
                logger.error("[AUTH_ERROR] Login parceiro falhou (landing)", {
                    email,
                    authErrorCode: error?.code,
                    authErrorStatus: error?.status,
                    authErrorName: error?.name,
                    authErrorMessage: error?.message,
                });
                errorMessage = mapSupabaseAuthErrorMessage(error?.message, "partner", error?.code, error?.status);
            } else {
                return Astro.redirect("/parceiro/dashboard");
            }
        }
    }

    if (action === "register_password") {
        formNome = (data.get("nome")?.toString() || "").trim();
        formEmail = (data.get("email")?.toString() || "").trim().toLowerCase();
        formWhatsapp = (data.get("whatsapp")?.toString() || "").trim();
        formCpf = (data.get("cpf")?.toString() || "").trim();
        const password = data.get("password")?.toString() || "";
        const passwordConfirm = data.get("password_confirm")?.toString() || "";

        let resolvedGrupoId = formGrupoId;
        if (!resolvedGrupoId) {
            const supabaseSSR = getSupabaseServerClient(Astro.cookies);
            const { data: defaultGroup } = await supabaseSSR.from('grupos_parceiros').select('id').eq('tenant_id', formTenantId).ilike('nome', '%Ligeira%').maybeSingle();
            resolvedGrupoId = defaultGroup?.id || null;
        }

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (!resolvedGrupoId) {
            errorMessage = "Sistema em manutenção: Nenhum grupo padrão encontrado para cadastro.";
        } else if (!formNome || !formEmail || !formWhatsapp) {
            errorMessage = "Preencha nome, e-mail e WhatsApp para concluir seu cadastro.";
        } else if (!emailRegex.test(formEmail)) {
            errorMessage = "Forneça um endereço de e-mail válido no formato correto.";
        } else if (!password || password.length < 8) {
            errorMessage = "Sua senha deve ter no mínimo 8 caracteres.";
        } else if (password !== passwordConfirm) {
            errorMessage = "As senhas não conferem.";
        } else {
            const cleanWhatsapp = sanitizePhone(formWhatsapp);
            const cleanCpf = formCpf.replace(/\D/g, "");

            if (!isValidWhatsApp(cleanWhatsapp)) {
                errorMessage = "Informe um WhatsApp brasileiro válido com DDD e 11 dígitos.";
            } else {
                const supabaseSSR = getSupabaseServerClient(Astro.cookies);

                const { data: createdData, error: createUserError } = await supabaseAdmin.auth.admin.createUser({
                    email: formEmail,
                    password,
                    email_confirm: true,
                    user_metadata: {
                        full_name: formNome,
                    },
                });

                if (createUserError) {
                    logger.error("[AUTH_CREATE_USER_ERROR] Falha ao criar usuário parceiro na landing", {
                        email: formEmail,
                        createUserError,
                    });
                    if (createUserError.message?.toLowerCase().includes("already") || createUserError.message?.toLowerCase().includes("registered")) {
                        errorMessage = "Este e-mail já está cadastrado. Faça login para continuar.";
                        activeMode = "login";
                    } else {
                        errorMessage = "Não foi possível concluir o cadastro agora. Tente novamente em instantes.";
                    }
                } else if (createdData.user) {
                    const createdUserId = createdData.user.id;

                    const { error: profileError } = await supabaseAdmin
                        .from("profiles")
                        .upsert(
                            {
                                id: createdUserId,
                                tenant_id: formTenantId,
                                nome: formNome,
                                email: formEmail,
                                telefone: cleanWhatsapp,
                                cpf: cleanCpf || null,
                                tipo_usuario: "parceiro",
                                grupo_id: resolvedGrupoId,
                                status: "ativo",
                            },
                            {
                                onConflict: "id",
                            },
                        );

                    if (profileError) {
                        logger.error("[DB_ERROR] Erro ao criar/atualizar perfil na landing", {
                            userId: createdUserId,
                            profileError,
                        });
                        errorMessage = "Conta criada, mas houve falha ao concluir o perfil. Tente fazer login.";
                    } else {
                        const { data: loginData, error: loginError } = await supabaseSSR.auth.signInWithPassword({
                            email: formEmail,
                            password,
                        });

                        if (loginError || !loginData.session) {
                            logger.error("[AUTH_LOGIN_AFTER_CREATE_ERROR] Login automático falhou na landing", {
                                email: formEmail,
                                loginError,
                            });
                            successMessage = "Conta criada com sucesso. Agora faça login para continuar.";
                            activeMode = "login";
                        } else {
                            return Astro.redirect("/parceiro/dashboard");
                        }
                    }
                }
            }
        }
    } // fim: if (action === "register_password")
} // fim: if (Astro.request.method === "POST")

// URL para o botão "Já sou parceiro" da navbar/footer — SSR define activeMode=login
const loginUrl = `#signup`;
