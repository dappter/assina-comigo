    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-nav {
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            background-color: rgba(255, 255, 255, 0.8); /* surface color with alpha */
            border-bottom: 1px solid rgba(0, 0, 0, 0.1); /* outline-variant */
        }
        
        /* Otimizações de Conversão - Animações sutis e Sombras Premium */
        .btn-glow {
            box-shadow: 0 0 25px rgba(96, 40, 255, 0.4);
            animation: pulse-glow 3s infinite alternate;
        }
        
