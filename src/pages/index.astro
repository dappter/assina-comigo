    </nav>

    <!-- Hero Section -->
    <header class="relative pt-40 pb-24 overflow-hidden border-b border-primary/10" style="background: linear-gradient(135deg, #140030 0%, #1E0050 60%, #2D0080 100%);">
        <div class="max-w-7xl mx-auto px-6 grid xl:grid-cols-2 gap-16 items-center">
            
