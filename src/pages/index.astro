    <script type="module" is:inline>
        import * as THREE from 'three';

        // Máscaras de input e controle de abas sem recarregar a página.
        document.addEventListener('DOMContentLoaded', function() {
            function sanitizePhone(phone) {
                if (!phone) return '';
                const digitsOnly = phone.replace(/\D/g, '');
                if (digitsOnly.length === 13 && digitsOnly.startsWith('55')) {
                    return digitsOnly.slice(2);
                }
                return digitsOnly;
            }

            function formatPhoneDisplay(phone) {
                const digits = sanitizePhone(phone).slice(0, 11);
                if (!digits) return '';
                if (digits.length <= 2) return `(${digits}`;
                if (digits.length <= 6) return `(${digits.slice(0, 2)}) ${digits.slice(2)}`;
                if (digits.length <= 10) return `(${digits.slice(0, 2)}) ${digits.slice(2, 6)}-${digits.slice(6)}`;
                return `(${digits.slice(0, 2)}) ${digits.slice(2, 7)}-${digits.slice(7)}`;
            }

            function sanitizeCPF(cpf) {
                if (!cpf) return '';
                return cpf.replace(/\D/g, '');
            }

            function formatCPFDisplay(cpf) {
                const digits = sanitizeCPF(cpf).slice(0, 11);
                if (!digits) return '';
                if (digits.length <= 3) return digits;
                if (digits.length <= 6) return `${digits.slice(0, 3)}.${digits.slice(3)}`;
                if (digits.length <= 9) return `${digits.slice(0, 3)}.${digits.slice(3, 6)}.${digits.slice(6)}`;
                return `${digits.slice(0, 3)}.${digits.slice(3, 6)}.${digits.slice(6, 9)}-${digits.slice(9)}`;
            }

            function applyPhoneMask(input) {
                if (!input || input.dataset.maskBound === 'true') return;

                input.addEventListener('input', function() {
                    const formatted = formatPhoneDisplay(this.value);
                    const raw = sanitizePhone(this.value);
                    this.value = formatted;
                    this.dataset.rawValue = raw;
                });

                input.addEventListener('blur', function() {
                    this.dataset.rawValue = sanitizePhone(this.value);
                });

                const form = input.closest('form');
                if (form) {
                    form.addEventListener('submit', function() {
                        const rawValue = input.dataset.rawValue || sanitizePhone(input.value);
                        input.value = rawValue;
                    });
                }

                input.dataset.maskBound = 'true';
            }

            function applyCPFMask(input) {
                if (!input || input.dataset.maskBound === 'true') return;

                input.addEventListener('input', function() {
                    const formatted = formatCPFDisplay(this.value);
                    const raw = sanitizeCPF(this.value);
                    this.value = formatted;
                    this.dataset.rawValue = raw;
                });

                input.addEventListener('blur', function() {
                    this.dataset.rawValue = sanitizeCPF(this.value);
                });

                const form = input.closest('form');
                if (form) {
                    form.addEventListener('submit', function() {
                        const rawValue = input.dataset.rawValue || sanitizeCPF(input.value);
                        input.value = rawValue;
                    });
                }

                input.dataset.maskBound = 'true';
            }

            const tabRegister = document.getElementById('tab-register');
            const tabLogin = document.getElementById('tab-login');
            const panelRegister = document.getElementById('panel-register');
            const panelLogin = document.getElementById('panel-login');

            function activateTab(tab) {
                if (!tabRegister || !tabLogin || !panelRegister || !panelLogin) return;
                const isRegister = tab === 'register';

                panelRegister.classList.toggle('hidden', !isRegister);
                panelLogin.classList.toggle('hidden', isRegister);

                tabRegister.classList.toggle('bg-white', isRegister);
                tabRegister.classList.toggle('text-slate-900', isRegister);
                tabRegister.classList.toggle('shadow', isRegister);
                tabRegister.classList.toggle('text-on-surface-variant', !isRegister);
                tabRegister.setAttribute('aria-selected', isRegister ? 'true' : 'false');

                tabLogin.classList.toggle('bg-white', !isRegister);
                tabLogin.classList.toggle('text-slate-900', !isRegister);
                tabLogin.classList.toggle('shadow', !isRegister);
                tabLogin.classList.toggle('text-on-surface-variant', isRegister);
                tabLogin.setAttribute('aria-selected', isRegister ? 'false' : 'true');

                if (isRegister) {
                    applyPhoneMask(document.getElementById('whatsapp'));
                    applyCPFMask(document.getElementById('cpf'));
                }
            }

            window.activateTab = activateTab;
            tabRegister && tabRegister.addEventListener('click', function() { activateTab('register'); });
            tabLogin && tabLogin.addEventListener('click', function() { activateTab('login'); });

            const initialRegisterSelected = tabRegister?.getAttribute('aria-selected') === 'true';
            activateTab(initialRegisterSelected ? 'register' : 'login');

            if (window.location.hash === '#login') {
                activateTab('login');
            }

        });
    </script>


