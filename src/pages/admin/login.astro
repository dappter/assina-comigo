---
import { getSupabaseServerClient } from "../../lib/supabaseSSR";
import { logger } from "../../utils/logger";
import { mapSupabaseAuthErrorMessage } from "../../utils/authErrors";

const ADMIN_BYPASS_EMAIL = "admin@topconexoes.com";
const ADMIN_BYPASS_PASSWORD = "adm123";
const ADMIN_BYPASS_COOKIE = "admin_bypass_session";

let errorMessage = "";
let emailAddress = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get("action");
        const contact = formData.get("contact")?.toString().trim().toLowerCase();

        logger.info("[ADMIN_LOGIN_POST] Pedido recebido", { action, contact });

        if (action === "login_password") {
            emailAddress = contact || "";
            const password = formData.get("password")?.toString() || "";

            if (!emailAddress || !emailAddress.includes("@") || !password || password.length < 6) {
                errorMessage = "Por favor, informe um e-mail corporativo valido e uma senha com pelo menos 6 caracteres.";
            } else {
                if (emailAddress === ADMIN_BYPASS_EMAIL && password === ADMIN_BYPASS_PASSWORD) {
                    Astro.cookies.set(ADMIN_BYPASS_COOKIE, "1", {
                        path: "/",
                        httpOnly: true,
                        sameSite: "lax",
                        secure: Astro.url.protocol === "https:",
                        maxAge: 60 * 60 * 24,
                    });

                    logger.info("[ADMIN_LOGIN_BYPASS_SUCCESS] Acesso administrativo via credencial fixa", {
                        email: emailAddress,
                    });
                    return Astro.redirect("/admin/dashboard");
                }

                const supabaseSSR = getSupabaseServerClient(Astro.cookies);
                const { data: sessionData, error: authError } = await supabaseSSR.auth.signInWithPassword({
                    email: emailAddress,
                    password,
                });

                if (authError || !sessionData.session) {
                    logger.error(
                        "[ADMIN_LOGIN_AUTH_ERROR] Falha no signInWithPassword",
                        {
                            email: emailAddress,
                            authErrorCode: authError?.code,
                            authErrorStatus: authError?.status,
                            authErrorName: authError?.name,
                            authErrorMessage: authError?.message,
                        },
                        authError,
                    );
                    errorMessage = mapSupabaseAuthErrorMessage(
                        authError?.message,
                        "admin",
                        authError?.code,
                        authError?.status,
                    );
                } else {
                    logger.info("[ADMIN_LOGIN_SUCCESS] Sessao criada", {
                        email: emailAddress,
                        userId: sessionData.session.user.id,
                    });

                    // Verifica se o usuário realmente possui role administrativa.
                    const { data: profile, error: dbError } = await supabaseSSR
                        .from("profiles")
                        .select("tipo_usuario")
                        .eq("id", sessionData.session.user.id)
                        .maybeSingle();

                    if (dbError) {
                        logger.error(
                            "[ADMIN_LOGIN_DB_ERROR] Falha ao validar role no profile",
                            {
                                email: emailAddress,
                                userId: sessionData.session.user.id,
                                dbErrorCode: dbError.code,
                                dbErrorMessage: dbError.message,
                            },
                            dbError,
                        );
                        errorMessage = "Nao foi possivel validar suas permissoes agora. Tente novamente em instantes.";
                        await supabaseSSR.auth.signOut();
                    } else if (!profile || profile.tipo_usuario !== "admin") {
                        logger.warn("[ADMIN_LOGIN_UNAUTHORIZED] Conta sem privilegio admin", {
                            email: emailAddress,
                            userId: sessionData.session.user.id,
                            profileRole: profile?.tipo_usuario,
                        });
                        errorMessage = "Acesso negado. Esta conta nao possui privilegios administrativos.";
                        await supabaseSSR.auth.signOut();
                    } else {
                        logger.info("[ADMIN_LOGIN_REDIRECT] Redirecionando para dashboard", {
                            userId: sessionData.session.user.id,
                        });
                        return Astro.redirect("/admin/dashboard");
                    }
                }
            }
        }
    } catch (err: any) {
        logger.error("[ADMIN_LOGIN_CRITICAL_ERROR] Erro inesperado", {}, err);
        errorMessage = "Ocorreu um erro inesperado ao autenticar. Tente novamente.";
    }
}
---

<!doctype html>
<html lang="pt-br">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <title>Acesso Admin — Assina Comigo</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@700;800&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined"
            rel="stylesheet"
        />
        <style>
            *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

            :root {
                --brand-primary: #6028FF;
                --brand-primary-dark: #4B1AC8;
                --brand-secondary: #FFBF1A;
                --sidebar-bg: #140030;
                --text-on-dark: #F1F5F9;
                --text-on-dark-dim: #94A3B8;
                --border-dark: rgba(255,255,255,0.08);
                --border-dark-hover: rgba(96,40,255,0.35);
                --surface-dark: rgba(255,255,255,0.04);
                --shadow-glow: 0 0 30px rgba(96, 40, 255, 0.2);
                --radius: 12px;
            }

            html, body {
                min-height: 100dvh;
                font-family: 'Inter', sans-serif;
                -webkit-font-smoothing: antialiased;
            }

            body {
                background: var(--sidebar-bg);
                background-image:
                    radial-gradient(ellipse at top right, rgba(96,40,255,0.15) 0%, transparent 60%),
                    radial-gradient(ellipse at bottom left, rgba(255,191,26,0.07) 0%, transparent 60%);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem 1.25rem;
            }

            .admin-card {
                width: 100%;
                max-width: 400px;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 2rem;
            }

            /* Header */
            .card-header {
                text-align: center;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 1rem;
            }
            .shield-icon {
                width: 64px;
                height: 64px;
                background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
                border-radius: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: var(--shadow-glow);
            }
            .shield-icon .material-symbols-outlined {
                font-size: 32px;
                color: white;
            }
            .card-header h1 {
                font-family: 'Outfit', sans-serif;
                font-size: 1.75rem;
                font-weight: 800;
                color: var(--text-on-dark);
                letter-spacing: -0.02em;
            }
            .card-header p {
                font-size: 0.875rem;
                color: var(--text-on-dark-dim);
            }
            .admin-badge {
                display: inline-flex;
                align-items: center;
                gap: 0.375rem;
                padding: 0.25rem 0.875rem;
                background: rgba(96,40,255,0.15);
                border: 1px solid rgba(96,40,255,0.3);
                border-radius: 100px;
                font-size: 0.7rem;
                font-weight: 700;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: #c4adff;
            }

            /* Main form area */
            .card-body {
                width: 100%;
                background: rgba(255,255,255,0.04);
                border: 1px solid rgba(255,255,255,0.07);
                border-radius: 20px;
                padding: 2rem;
                backdrop-filter: blur(12px);
            }

            /* Alert messages */
            .alert {
                margin-bottom: 1.5rem;
                padding: 0.875rem 1rem;
                border-radius: var(--radius);
                font-size: 0.875rem;
                font-weight: 500;
                display: flex;
                align-items: flex-start;
                gap: 0.5rem;
            }
            .alert .material-symbols-outlined { font-size: 18px; flex-shrink: 0; color: #FDA4AF; }
            .alert-error {
                background: rgba(255,68,102,0.1);
                border: 1px solid rgba(255,68,102,0.25);
                color: #FDA4AF;
            }

            /* Google button */
            .btn-google {
                width: 100%;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.625rem;
                padding: 0.875rem;
                background: var(--surface-dark);
                border: 1px solid var(--border-dark);
                border-radius: var(--radius);
                font-size: 0.95rem;
                font-weight: 600;
                color: var(--text-on-dark);
                cursor: pointer;
                transition: all 0.15s ease;
                margin-bottom: 0;
            }
            .btn-google:hover {
                border-color: var(--border-dark-hover);
                background: rgba(96,40,255,0.08);
            }
            .btn-google img { width: 20px; height: 20px; }

            /* Divider */
            .divider {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                margin: 1.25rem 0;
            }
            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border-dark);
            }
            .divider span {
                font-size: 0.7rem;
                font-weight: 700;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--text-on-dark-dim);
                white-space: nowrap;
            }

            /* Form inputs */
            .field { margin-bottom: 1rem; }
            .field label {
                display: block;
                font-size: 0.8rem;
                font-weight: 600;
                color: var(--text-on-dark-dim);
                margin-bottom: 0.375rem;
            }
            .field input {
                width: 100%;
                padding: 0.875rem 1rem;
                background: rgba(0,0,0,0.25);
                border: 1px solid var(--border-dark);
                border-radius: var(--radius);
                font-size: 0.95rem;
                font-family: 'Inter', sans-serif;
                color: var(--text-on-dark);
                outline: none;
                transition: all 0.15s ease;
            }
            .field input::placeholder { color: rgba(148,163,184,0.5); }
            .field input:focus {
                border-color: var(--brand-primary);
                box-shadow: 0 0 0 3px rgba(96,40,255,0.15);
            }

            /* Submit button */
            .btn-submit {
                width: 100%;
                padding: 1rem;
                background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
                color: white;
                border: none;
                border-radius: var(--radius);
                font-size: 1rem;
                font-family: 'Outfit', sans-serif;
                font-weight: 700;
                cursor: pointer;
                transition: all 0.15s ease;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                margin-top: 0.5rem;
                box-shadow: var(--shadow-glow);
            }
            .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 24px rgba(96,40,255,0.35);
            }
            .btn-submit .material-symbols-outlined { font-size: 20px; }

            /* Footer */
            .card-footer {
                text-align: center;
                font-size: 0.75rem;
                color: var(--text-on-dark-dim);
            }
            .card-footer a {
                color: #c4adff;
                text-decoration: none;
                font-weight: 600;
            }
            .card-footer a:hover { color: var(--text-on-dark); }
        </style>
    </head>
    <body>
        <div class="admin-card">

            <!-- Header -->
            <div class="card-header">
                <div class="shield-icon">
                    <span class="material-symbols-outlined">shield_lock</span>
                </div>
                <div>
                    <h1>Admin Center</h1>
                    <p>Uso exclusivo para colaboradores</p>
                </div>
                <div class="admin-badge">
                    🔒 Acesso Restrito
                </div>
            </div>

            <!-- Form Card -->
            <div class="card-body">
                {errorMessage && (
                    <div class="alert alert-error">
                        <span class="material-symbols-outlined">error</span>
                        {errorMessage}
                    </div>
                )}

                <!-- Google OAuth removed for Admin -->

                <div class="divider"><span>ou use senha</span></div>

                <!-- Password Login -->
                <form method="POST" enctype="application/x-www-form-urlencoded">
                    <input type="hidden" name="action" value="login_password" />

                    <div class="field">
                        <label for="contact">E-mail Corporativo</label>
                        <input
                            id="contact"
                            name="contact"
                            type="email"
                            placeholder="admin@empresa.com.br"
                            value={emailAddress}
                            autocomplete="email"
                            inputmode="email"
                            required
                        />
                    </div>

                    <div class="field">
                        <label for="password">Senha</label>
                        <input
                            id="password"
                            name="password"
                            type="password"
                            placeholder="••••••••"
                            minlength="6"
                            autocomplete="current-password"
                            required
                        />
                    </div>

                    <button type="submit" class="btn-submit">
                        Entrar no Sistema
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                </form>
            </div>

            <!-- Footer -->
            <div class="card-footer">
                <p>
                    &copy; {new Date().getFullYear()} Assina Comigo ISP. Todos os direitos reservados.
                    <br/>
                    <a href="/parceiro/login">← Área de Parceiros</a>
                </p>
            </div>

        </div>
    </body>
</html>
