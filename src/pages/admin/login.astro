---
import { supabase as defaultSupabase } from "../../lib/supabaseClient";
import { getSupabaseServerClient } from "../../lib/supabaseSSR";

let errorMessage = "";
let successMessage = "";
let emailAddress = "";

if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData();
        const action = data.get("action");
        const contact = data.get("contact")?.toString();

        if (action === "login_password") {
            emailAddress = contact || "";
            const password = data.get("password")?.toString();

            if (!emailAddress || !emailAddress.includes("@") || !password) {
                errorMessage =
                    "Por favor, insira um e-mail válido e uma senha.";
            } else {
                const supabaseSSR = getSupabaseServerClient(Astro.cookies);
                const { data: sessionData, error } =
                    await supabaseSSR.auth.signInWithPassword({
                        email: emailAddress,
                        password: password,
                    });

                if (error || !sessionData.session) {
                    errorMessage =
                        error?.message || "E-mail ou senha incorretos.";
                } else {
                    // Verify if user is actually admin
                    const { data: profile } = await supabaseSSR
                        .from("profiles")
                        .select("tipo_usuario")
                        .eq("id", sessionData.session.user.id)
                        .single();

                    if (profile?.tipo_usuario !== "admin") {
                        errorMessage =
                            "Acesso negado. Esta conta não possui privilégios administrativos.";
                        await supabaseSSR.auth.signOut();
                    } else {
                        return Astro.redirect("/admin/dashboard");
                    }
                }
            }
        } else if (action === "oauth_google") {
            const { data: authData, error } = await defaultSupabase.auth.signInWithOAuth({
                provider: "google",
                options: {
                    redirectTo: `${Astro.url.origin}/api/auth/callback?next=/admin/dashboard`,
                },
            });
            if (error) {
                errorMessage = error.message;
            } else if (authData.url) {
                return Astro.redirect(authData.url);
            }
        }
    } catch (error) {
        if (error instanceof Error) {
            if (error.message.includes("Content-Type was not one of")) {
                errorMessage =
                    "Erro de conexão. O navegador falhou ao enviar os dados.";
            } else {
                errorMessage = error.message;
            }
        } else {
            errorMessage = "Ocorreu um erro inesperado.";
        }
    }
}
---

<!doctype html>
<html class="light" lang="pt-br">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <title>Login Administrativo - Assina Comigo</title>
        <script
            is:inline
            src="https://cdn.tailwindcss.com?plugins=forms,container-queries"
        ></script>
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@600;700;800;900&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />
        <script is:inline>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            "admin-primary": "#FF4466",
                            "admin-dark": "#0F172A",
                        },
                        fontFamily: {
                            display: ["Inter", "sans-serif"],
                            outfit: ["Outfit", "sans-serif"],
                        },
                    },
                },
            };
        </script>
        <style>
            body {
                font-family: "Inter", sans-serif;
                background-color: #0f172a;
            }
            .admin-shadow {
                box-shadow: 0 0 40px rgba(255, 68, 102, 0.15);
            }
        </style>
    </head>
    <body
        class="min-h-screen flex flex-col items-center justify-center p-6 bg-slate-950 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-900 via-slate-950 to-black"
    >
        <div
            class="w-full max-w-md flex flex-col items-center mb-8 relative z-10"
        >
            <div
                class="w-16 h-16 bg-admin-primary rounded-xl flex items-center justify-center mb-5 admin-shadow relative"
            >
                <span
                    class="material-symbols-outlined text-white text-3xl font-bold"
                    >shield_lock</span
                >
            </div>
            <h1
                class="text-3xl font-bold text-white text-center font-outfit tracking-tight"
            >
                Admin Center
            </h1>
            <p class="text-slate-400 text-sm mt-2 font-medium">
                Uso exclusivo para colaboradores.
            </p>
        </div>

        <main
            class="w-full max-w-md bg-slate-900/80 backdrop-blur-md rounded-2xl p-8 border border-slate-800 shadow-2xl relative z-10"
        >
            <div class="mb-8">
                <h2 class="text-xl font-bold text-white">Acesso Restrito</h2>
                <p class="text-slate-400 text-sm mt-1">
                    Identifique-se com suas credenciais administrativas.
                </p>
            </div>

            <form
                method="POST"
                class="mb-6"
                enctype="application/x-www-form-urlencoded"
            >
                <input type="hidden" name="action" value="oauth_google" />
                <button
                    type="submit"
                    class="w-full flex items-center justify-center gap-3 py-3.5 px-4 bg-slate-800 border border-slate-700 rounded-xl shadow-sm hover:bg-slate-700 transition-all font-bold text-white group"
                >
                    <img
                        src="https://www.svgrepo.com/show/475656/google-color.svg"
                        alt="Google Logo"
                        class="w-5 h-5 group-hover:scale-110 transition-transform"
                    />
                    Acesso Admin via Google
                </button>
            </form>

            <div class="relative flex py-2 items-center mb-6">
                <div class="flex-grow border-t border-slate-800"></div>
                <span class="flex-shrink-0 mx-4 text-[10px] font-bold text-slate-600 uppercase tracking-widest">ou use senha</span>
                <div class="flex-grow border-t border-slate-800"></div>
            </div>

            {
                errorMessage && (
                    <div class="mb-6 p-4 bg-red-950/50 border border-red-900 rounded-xl text-red-500 text-sm text-center font-medium">
                        {errorMessage === "Invalid login credentials"
                            ? "E-mail ou senha inválidos."
                            : errorMessage}
                    </div>
                )
            }

            <form
                class="space-y-6"
                method="POST"
                enctype="application/x-www-form-urlencoded"
            >
                <input type="hidden" name="action" value="login_password" />
                <div class="space-y-4">
                    <div>
                        <label
                            class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2 ml-1"
                            for="contact"
                        >
                            E-mail Corporativo
                        </label>
                        <input
                            class="w-full px-4 py-3.5 bg-slate-950 border border-slate-800 rounded-xl text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-admin-primary focus:border-admin-primary transition-all"
                            id="contact"
                            name="contact"
                            placeholder="admin@empresa.com.br"
                            type="email"
                            required
                        />
                    </div>
                    <div>
                        <label
                            class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2 ml-1"
                            for="password"
                        >
                            Senha
                        </label>
                        <input
                            class="w-full px-4 py-3.5 bg-slate-950 border border-slate-800 rounded-xl text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-admin-primary focus:border-admin-primary transition-all"
                            id="password"
                            name="password"
                            placeholder="••••••••"
                            type="password"
                            required
                        />
                    </div>
                </div>

                <button
                    class="w-full bg-admin-primary hover:bg-rose-500 active:scale-[0.98] transition-all text-white font-bold py-4 rounded-xl shadow-lg shadow-admin-primary/20 flex items-center justify-center gap-2 mt-4"
                    type="submit"
                >
                    Entrar no Sistema
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </form>
        </main>

        <div class="mt-8 text-center text-slate-500 text-xs font-medium">
            &copy; {new Date().getFullYear()} Assina Comigo ISP. Todos os direitos
            reservados.
        </div>
    </body>
</html>
