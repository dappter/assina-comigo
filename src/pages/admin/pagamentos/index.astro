---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import Badge from "../../../components/ui/Badge.astro";
import Button from "../../../components/ui/Button.astro";
import { DollarSign, Clock, AlertCircle, CheckCircle2, Trash2 } from "@lucide/astro";
import { adminService } from "../../../services/adminService";

const tenantId = Astro.locals.tenantId;

if (!tenantId) {
    return Astro.redirect("/admin/login");
}

let notification = "";

// Handle status updates
if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get("action");
        const comissaoId = formData.get("comissao_id") as string;
        const valorEditado = formData.get("valor") ? Number(formData.get("valor")) : undefined;
        const paymentConfirmed = formData.get("confirm_payment")?.toString() === "yes";
        
        if (action === "approve" && comissaoId) {
            await adminService.approvePagamento(comissaoId, tenantId);
            notification = "success|Comissão aprovada e movida para A Pagar.";
        } else if (action === "delete" && comissaoId) {
            await adminService.deletePagamento(comissaoId, tenantId);
            notification = "success|Comissão excluída com sucesso.";
        } else if (action === "pay" && comissaoId) {
            if (!paymentConfirmed) {
                throw new Error("Confirme que o pagamento real foi efetuado antes de marcar como pago.");
            }
            await adminService.updatePagamento(comissaoId, "pago", tenantId, valorEditado, true);
            notification = "success|Pagamento marcado como pago com sucesso!";
        } else if (action === "pay_points" && comissaoId) {
            if (!paymentConfirmed) {
                throw new Error("Confirme a conversão real antes de concluir em pontos.");
            }
            await adminService.updatePagamento(comissaoId, "pago_pontos", tenantId, valorEditado, true);
            notification = "success|Pontos creditados com sucesso ao parceiro!";
        }
    } catch (err: any) {
        notification = `error|${err.message || "Erro."}`;
    }
}

// Fetch list after potential changes
const pagamentos = await adminService.getPagamentos(tenantId);

const formatMoney = (v: number) =>
    new Intl.NumberFormat("pt-BR", {
        style: "currency",
        currency: "BRL",
    }).format(v || 0);

const pendentesAprovacao = pagamentos.filter((p) => (p.status || "").toLowerCase() === "pendente");
const aPagar = pagamentos.filter((p) => (p.status || "").toLowerCase() === "a_pagar");
const pagos = pagamentos.filter((p) => (p.status || "").toLowerCase() === "pago");

const totalAPagarDinheiro = aPagar.filter(p => p.tipo !== 'pontos').reduce((acc, curr) => acc + (curr.valor || 0), 0);
const totalAPagarPontos = aPagar.filter(p => p.tipo === 'pontos').reduce((acc, curr) => acc + (curr.valor || 0), 0);

const totalHistoricoDinheiro = pagos.filter(p => p.tipo !== 'pontos').reduce((acc, curr) => acc + (curr.valor || 0), 0);
const totalHistoricoPontos = pagos.filter(p => p.tipo === 'pontos').reduce((acc, curr) => acc + (curr.valor || 0), 0);
---

<AdminLayout title="Gestão de Pagamentos">
    <div class="admin-page">
        <header class="page-header">
            <div>
                <h1 class="page-title">Pagamentos aos Parceiros</h1>
                <p class="subtitle">
                    Aprovações de comissões e gestão financeira de indicações
                    instaladas.
                </p>
            </div>
        </header>

        {
            notification && (
                <div class={`notification ${notification.split("|")[0]}`}>
                    {notification.split("|")[1]}
                </div>
            )
        }

        <div class="stats-overview">
            <div class="stat-card">
                <span class="stat-label">Dinheiro a Pagar (Filtrado)</span>
                <span class="stat-value text-primary" id="displayTotalAPagar"
                    >{formatMoney(totalAPagarDinheiro)}</span
                >
            </div>
            <div class="stat-card">
                <span class="stat-label">Dinheiro Pago (Filtrado)</span>
                <span class="stat-value text-success" id="displayTotalHistorico"
                    >{formatMoney(totalHistoricoDinheiro)}</span
                >
            </div>
            <div class="stat-card">
                <span class="stat-label">Pontos a Creditar (Filtrado)</span>
                <span class="stat-value text-amber" id="displayTotalAPagarPontos"
                    >{totalAPagarPontos} pts</span
                >
            </div>
            <div class="stat-card">
                <span class="stat-label">Pontos Concluídos (Filtrado)</span>
                <span class="stat-value text-blue" id="displayTotalHistoricoPontos"
                    >{totalHistoricoPontos} pts</span
                >
            </div>
        </div>

        <div class="table-container">
            <div class="tabs-header">
                <div class="tabs-list">
                    <button class="tab active" onclick="showTab('pendentes')"
                        >Aprovação ({pendentesAprovacao.length})</button
                    >
                    <button class="tab" onclick="showTab('apagar')"
                        >A Pagar ({aPagar.length})</button
                    >
                    <button class="tab" onclick="showTab('pagos')"
                        >Histórico Pago ({pagos.length})</button
                    >
                </div>
                <!-- Filtro por Parceiro -->
                <div class="filter-box">
                    <input
                        type="text"
                        id="partnerSearch"
                        placeholder="Filtrar por parceiro..."
                        class="search-input"
                    />
                </div>
            </div>

            <div id="tab-pendentes" class="tab-content active">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Parceiro</th>
                            <th>Referência</th>
                            <th>Tipo</th>
                            <th>Valor/Qtd</th>
                            <th class="text-right">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        {
                            pendentesAprovacao.length === 0 ? (
                                <tr>
                                    <td colspan="5" class="text-center empty-state">
                                        Nenhuma comissão aguardando aprovação.
                                    </td>
                                </tr>
                            ) : (
                                pendentesAprovacao.map((p) => (
                                    <tr
                                        class="payment-row"
                                        data-partner={p.parceiro?.nome?.toLowerCase() || ""}
                                        data-value={p.valor || 0}
                                        data-tipo={p.tipo || 'dinheiro'}
                                    >
                                        <td><strong>{p.parceiro?.nome || "Desconhecido"}</strong></td>
                                        <td>{p.lead?.nome || "N/A"}</td>
                                        <td>
                                            <Badge variant={p.tipo === 'pontos' ? 'neutral' : 'warning'}>
                                                {p.tipo === 'pontos' ? '🏆 Pontos' : '💰 Dinheiro'}
                                            </Badge>
                                        </td>
                                        <td class="money-text">
                                            {p.tipo === 'pontos' ? `${p.valor} pts` : formatMoney(p.valor)}
                                        </td>
                                        <td class="text-right">
                                            <div class="row-actions">
                                                <form method="POST" style="display: inline;">
                                                    <input type="hidden" name="action" value="approve" />
                                                    <input type="hidden" name="comissao_id" value={p.id} />
                                                    <button type="submit" class="btn-pay-modal" style="background: #0f766e; border-color: #0f766e;">
                                                        <CheckCircle2 size={16} /> Aprovar
                                                    </button>
                                                </form>
                                                <form method="POST" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir esta comissão?');">
                                                    <input type="hidden" name="action" value="delete" />
                                                    <input type="hidden" name="comissao_id" value={p.id} />
                                                    <button type="submit" class="btn-delete" title="Excluir comissão">
                                                        <Trash2 size={16} />
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                ))
                            )
                        }
                    </tbody>
                </table>
            </div>

            <div id="tab-apagar" class="tab-content" style="display: none;">
                <table class="admin-table">
                    <thead>
                        <tr>
                             <th>Parceiro</th>
                             <th>Referência</th>
                             <th>Tipo</th>
                             <th>Valor/Qtd</th>
                             <th class="text-right">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        {
                            aPagar.length === 0 ? (
                                <tr>
                                    <td
                                        colspan="5"
                                        class="text-center empty-state"
                                    >
                                        Nenhum pagamento pronto para saque.
                                    </td>
                                </tr>
                            ) : (
                                aPagar.map((p) => {
                                    return (
                                        <tr
                                            class="payment-row"
                                            data-partner={
                                                p.parceiro?.nome?.toLowerCase() ||
                                                ""
                                            }
                                            data-value={p.valor || 0}
                                            data-tipo={p.tipo || 'dinheiro'}
                                        >
                                            <td>
                                                <strong>
                                                    {p.parceiro?.nome ||
                                                        "Desconhecido"}
                                                </strong>
                                            </td>
                                             <td>{p.lead?.nome || "N/A"}</td>
                                             <td>
                                                 <Badge variant={p.tipo === 'pontos' ? 'neutral' : 'success'}>
                                                     {p.tipo === 'pontos' ? '🏆 Pontos' : '💰 Dinheiro'}
                                                 </Badge>
                                             </td>
                                             <td class="money-text">
                                                 {p.tipo === 'pontos' ? `${p.valor} pts` : formatMoney(p.valor)}
                                             </td>
                                             <td class="text-right">
                                                 <div class="row-actions">
                                                    <button
                                                        type="button"
                                                        class="btn-pay-modal"
                                                        onclick={`openPixModal('${p.id}', '${p.parceiro?.nome?.replace(/'/g, "\\'")}', '${p.parceiro?.chave_pix || ""}', '${p.parceiro?.tipo_pix || ""}', ${p.valor}, '${p.tipo}')`}
                                                    >
                                                        <DollarSign size={16} />{" "}
                                                        Analisar
                                                    </button>
                                                    <form method="POST" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir esta comissão?');">
                                                        <input type="hidden" name="action" value="delete" />
                                                        <input type="hidden" name="comissao_id" value={p.id} />
                                                        <button type="submit" class="btn-delete" title="Excluir comissão">
                                                            <Trash2 size={16} />
                                                        </button>
                                                    </form>
                                                 </div>
                                             </td>
                                        </tr>
                                    );
                                })
                            )
                        }
                    </tbody>
                </table>
            </div>

            <div id="tab-pagos" class="tab-content" style="display: none;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Parceiro</th>
                            <th>Lead Referência</th>
                            <th>Status</th>
                            <th>Valor Pago</th>
                            <th>Data</th>
                        </tr>
                    </thead>
                    <tbody>
                        {
                            pagos.length === 0 ? (
                                <tr>
                                    <td
                                        colspan="5"
                                        class="text-center empty-state"
                                    >
                                        Nenhum histórico de pagamentos.
                                    </td>
                                </tr>
                            ) : (
                                pagos.map((p) => (
                                    <tr
                                        class="payment-row"
                                        data-partner={
                                            p.parceiro?.nome?.toLowerCase() ||
                                            ""
                                        }
                                        data-value={p.valor || 0}
                                        data-tipo={p.tipo || 'dinheiro'}
                                    >
                                        <td>
                                            <strong>
                                                {p.parceiro?.nome ||
                                                    "Desconhecido"}
                                            </strong>
                                        </td>
                                        <td>{p.lead?.nome || "N/A"}</td>
                                        <td>
                                            <Badge variant="success">
                                                Pago
                                            </Badge>
                                        </td>
                                        <td class="money-text">
                                            {p.tipo === 'pontos' ? `${p.valor} pts` : formatMoney(p.valor)}
                                        </td>
                                        <td class="col-date">
                                            {new Date(
                                                p.created_at,
                                            ).toLocaleDateString()}
                                        </td>
                                    </tr>
                                ))
                            )
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal PIX Dinâmico -->
    <dialog id="pixModal" class="pix-dialog">
        <div class="pix-content">
            <div class="pix-header">
                <h3>Realizar Pagamento</h3>
                <button
                    type="button"
                    class="close-btn"
                    onclick="document.getElementById('pixModal').close()"
                    >✕</button
                >
            </div>
            <div class="pix-body">
                <p>Transferindo PIX para: <br/><strong id="pixPartnerName" style="font-size:1.1rem; color:var(--color-heading);"></strong></p>
                
                <div class="pix-value-container" style="margin-bottom: 1.5rem; text-align: center;">
                    <label for="pixValueInput" style="display: block; font-size: 0.8rem; font-weight: 700; color: var(--color-subtle); text-transform: uppercase; margin-bottom: 0.5rem;">Valor a Pagar (R$)</label>
                    <input type="number" id="pixValueInput" step="0.01" min="0" class="pix-value-edit" style="width: 100%; text-align: center; font-size: 2.5rem; font-weight: 800; color: #10b981; border: 1px dashed #cbd5e1; border-radius: 12px; padding: 0.5rem; background: #f0fdf4;" />
                </div>
                <div id="pixDetailsArea">
                    <div
                        id="pixQrCodeContainer"
                        style="display:none; margin: 1rem auto; text-align: center;"
                    >
                        <a
                            id="pixQrCodeLink"
                            href="#"
                            target="_blank"
                            title="Abrir imagem do QR Code em tela cheia"
                        >
                            <img
                                id="pixQrCode"
                                src=""
                                alt="QR Code PIX"
                                style="width: 200px; height: 200px; border-radius: 8px; border: 1px solid #e2e8f0; padding: 0.5rem; background: white;"
                            />
                        </a>
                        <p
                            style="font-size: 0.8rem; color: #64748b; margin-top: 0.5rem;"
                        >
                            Escaneie com o app do seu banco
                        </p>

                        <div
                            style="margin-top: 0.5rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;"
                        >
                            <input
                                type="text"
                                id="pixQrUrlInput"
                                readonly
                                title="Conteúdo / Link do QR Code"
                                value=""
                                style="font-size: 0.75rem; color: #64748b; border: 1px solid #e2e8f0; border-radius: 4px; padding: 0.4rem 0.5rem; width: 140px; background: #f8fafc;"
                            />
                            <button
                                type="button"
                                class="copy-pix-btn"
                                id="btnCopyQrUrl"
                                onclick="copyQrUrl()"
                                style="padding: 0.4rem 0.6rem; font-size: 0.75rem;"
                                >Copiar Payload</button
                            >
                        </div>
                    </div>

                    <div class="pix-key-box" id="pixKeyBox">
                        <div class="pix-key-info">
                            <span class="pix-type" id="pixType">Chave</span>
                            <strong class="pix-key" id="pixKey"></strong>
                        </div>
                        <button
                            type="button"
                            class="copy-pix-btn"
                            onclick="copyPix()">Copiar</button
                        >
                    </div>
                </div>

                <p
                    id="pixWarning"
                    style="display:none; color:#dc2626; font-size:0.85rem; margin-top:0.5rem; background: #fee2e2; padding: 0.5rem; border-radius: 6px;"
                >
                    O parceiro não cadastrou chave PIX no perfil. Contate-o ou
                    pague manualmente.
                </p>

                <form
                    method="POST"
                    id="formPayNow"
                    style="margin-top: 1.5rem; display: grid; grid-template-columns: 1fr; gap: 1rem;"
                >
                    <input
                        type="hidden"
                        name="action"
                        id="pixAction"
                        value="pay"
                    />
                    <input
                        type="hidden"
                        name="comissao_id"
                        id="pixComissaoId"
                        value=""
                    />
                    <input type="hidden" name="valor" id="pixValorFinal" value="" />
                    <input type="hidden" name="confirm_payment" id="confirmPaymentHidden" value="no" />

                    <label class="confirm-payment-check">
                        <input type="checkbox" id="confirmPaymentCheck" />
                        <span>Confirmo que o pagamento foi realmente efetuado (ou pontos realmente creditados).</span>
                    </label>

                    <Button
                        type="submit"
                        variant="primary"
                        style="background: #10b981; border-color: #10b981;"
                        id="btnConfirmPay"
                    >
                        <CheckCircle2 size={18} style="margin-right: 0.5rem;" /> Marcar como Pago (Dinheiro)
                    </Button>

                    <Button
                        type="button"
                        variant="primary"
                        style="background: #3b82f6; border-color: #3b82f6; display: none;"
                        id="btnConfirmPoints"
                        onclick="payPoints()"
                    >
                        🏆 Premiar com Pontos
                    </Button>
                </form>
            </div>
        </div>
    </dialog>

    <script is:inline>
        function showTab(id) {
            document
                .querySelectorAll(".tab-content")
                .forEach((el) => (el.style.display = "none"));
            document
                .querySelectorAll(".tab")
                .forEach((el) => el.classList.remove("active"));
            document.getElementById("tab-" + id).style.display = "block";
            event.currentTarget.classList.add("active");
        }

        // Sistema de busca por parceiro e totalização dinâmica
        const partnerSearch = document.getElementById("partnerSearch");
        const displayTotalAPagar = document.getElementById("displayTotalAPagar");
        const displayTotalHistorico = document.getElementById("displayTotalHistorico");
        const displayTotalAPagarPts = document.getElementById("displayTotalAPagarPontos");
        const displayTotalHistoricoPts = document.getElementById("displayTotalHistoricoPontos");

        partnerSearch?.addEventListener("input", (e) => {
            const term = e.target.value.toLowerCase();
            let sumAPagar = 0;
            let sumPagos = 0;
            let sumAPagarPts = 0;
            let sumPagosPts = 0;

            document.querySelectorAll(".payment-row").forEach((row) => {
                const partnerName = row.getAttribute("data-partner") || "";
                const isVisible = partnerName.includes(term);
                const tipo = row.getAttribute("data-tipo") || "dinheiro";
                const valueAttr = row.getAttribute("data-value") || "0";
                const value = parseFloat(valueAttr);
                
                row.style.display = isVisible ? "" : "none";

                if (isVisible) {
                    const isAPagarTab = row.closest("#tab-apagar");
                    if (isAPagarTab) {
                        if (tipo === 'pontos') sumAPagarPts += value;
                        else sumAPagar += value;
                    } else {
                        if (tipo === 'pontos') sumPagosPts += value;
                        else sumPagos += value;
                    }
                }
            });

            const formatter = new Intl.NumberFormat("pt-BR", {
                style: "currency",
                currency: "BRL",
            });
            
            if (displayTotalAPagar) displayTotalAPagar.textContent = formatter.format(sumAPagar);
            if (displayTotalHistorico) displayTotalHistorico.textContent = formatter.format(sumPagos);
            if (displayTotalAPagarPts) displayTotalAPagarPts.textContent = sumAPagarPts + " pts";
            if (displayTotalHistoricoPts) displayTotalHistoricoPts.textContent = sumPagosPts + " pts";
        });

        function openPixModal(id, name, pixKey, pixType, valor, tipo) {
             document.getElementById("pixComissaoId").value = id;
             document.getElementById("pixPartnerName").textContent = name;
               document.getElementById("confirmPaymentCheck").checked = false;
               document.getElementById("confirmPaymentHidden").value = "no";

             const inputValor = document.getElementById('pixValueInput');
             inputValor.value = valor;
             document.getElementById('pixValorFinal').value = valor;

             // Guardar dados para regeneração dinâmica
             pixModal._currentData = { pixKey, name, pixType, tipo };

             // Ajustar visibilidade de botões conforme o tipo
             const btnConfirmPay = document.getElementById("btnConfirmPay");
             const btnConfirmPoints = document.getElementById("btnConfirmPoints");
             const pixDetails = document.getElementById("pixDetailsArea");

             if (tipo === 'pontos') {
                btnConfirmPay.style.display = 'none';
                btnConfirmPoints.style.display = 'flex';
                pixDetails.style.display = 'none';
             } else {
                btnConfirmPay.style.display = 'flex';
                btnConfirmPoints.style.display = 'none';
                pixDetails.style.display = 'block';
             }

             updatePixDisplay(pixKey, name, valor, pixType);

             document.getElementById("pixModal").showModal();
         }

        // Função para atualizar o display do PIX (QR Code e Payload)
        function updatePixDisplay(pixKey, name, valor, pixType) {
            if (pixKey && pixKey !== "null" && pixKey !== "undefined" && pixKey !== "") {
                document.getElementById("pixKeyBox").style.display = "flex";
                document.getElementById("pixQrCodeContainer").style.display = "block";
                document.getElementById("pixWarning").style.display = "none";
                document.getElementById("pixType").textContent = (pixType || "Chave PIX").toUpperCase();
                document.getElementById("pixKey").textContent = pixKey;

                // Usando API QRServer e Carga Real EMVCo (Platarforma PIX)
                const payloadPis = generatePixPayload(pixKey, name, valor, pixType);
                const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=250x250&format=svg&data=${encodeURIComponent(payloadPis)}`;

                document.getElementById("pixQrCode").src = qrUrl;
                document.getElementById("pixQrCodeLink").href = qrUrl;
                document.getElementById("pixQrUrlInput").value = payloadPis;
            } else {
                document.getElementById("pixKeyBox").style.display = "none";
                document.getElementById("pixQrCodeContainer").style.display = "none";
                document.getElementById("pixWarning").style.display = "block";
            }
        }

        // Listener para mudanças no valor
        document.getElementById('pixValueInput')?.addEventListener('input', (e) => {
            const novoValor = parseFloat(e.target.value) || 0;
            document.getElementById('pixValorFinal').value = novoValor;
            
            const data = document.getElementById('pixModal')._currentData;
            if (data) {
                updatePixDisplay(data.pixKey, data.name, novoValor, data.pixType);
            }
        });

        // --- FUNÇÕES EMVCo PIX ---
        function crc16(payload) {
            let crc = 0xffff;
            for (let i = 0; i < payload.length; i++) {
                crc ^= payload.charCodeAt(i) << 8;
                for (let j = 0; j < 8; j++) {
                    if ((crc & 0x8000) > 0) {
                        crc = (crc << 1) ^ 0x1021;
                    } else {
                        crc = crc << 1;
                    }
                    crc &= 0xffff; // Prevent JS signed shift bugs
                }
            }
            return crc.toString(16).toUpperCase().padStart(4, "0");
        }

        function formatValue(id, value) {
            const valStr = String(value);
            const len = valStr.length.toString().padStart(2, "0");
            return `${id}${len}${valStr}`;
        }

        function generatePixPayload(pixKey, merchantName, amount, pixType) {
            // Limpa o nome do recebedor (Max 25 chars, sem acentos, sem emojis)
            const cleanName =
                merchantName
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .replace(/[^a-zA-Z0-9\s]/g, "")
                    .trim()
                    .substring(0, 25) || "ASSINA COMIGO";

            // Limpa e ajusta a chave PIX dependendo do tipo
            let cleanKey = pixKey.trim();
            if (pixType === "cpf" || pixType === "cnpj") {
                cleanKey = cleanKey.replace(/\D/g, ""); // Numeros apenas
            } else if (pixType === "telefone") {
                cleanKey = cleanKey.replace(/\D/g, ""); // Remove formatação (11) 9...
                if (
                    !cleanKey.startsWith("55") &&
                    cleanKey.length >= 10 &&
                    cleanKey.length <= 11
                ) {
                    cleanKey = `+55${cleanKey}`;
                } else if (!cleanKey.startsWith("+")) {
                    cleanKey = `+${cleanKey}`;
                }
            }

            const fmtAmount = Number(amount).toFixed(2);

            // 26 - Merchant Account Info (Pix) -> 00 = gui, 01 = chave
            const gui = formatValue("00", "br.gov.bcb.pix");
            const keyInfo = formatValue("01", cleanKey);
            const merchantInfo = formatValue("26", gui + keyInfo);

            let payload = "";
            payload += formatValue("00", "01"); // Payload Format Indicator
            payload += merchantInfo; // Merchant Account Information
            payload += formatValue("52", "0000"); // Merchant Category Code

            // CRÍTICO: transação BR(Real) é 986 e não 0986 conforme padrão EMVCo
            payload += formatValue("53", "986"); // Transaction Currency (BRL = 986)

            payload += formatValue("54", fmtAmount); // Transaction Amount
            payload += formatValue("58", "BR"); // Country Code
            payload += formatValue("59", cleanName); // Merchant Name
            payload += formatValue("60", "SAO PAULO"); // Merchant City

            // 62 - Additional Data Field Template (Reference Label id 05)
            const txid = formatValue("05", "***");
            payload += formatValue("62", txid);

            // 63 - CRC16 (Fix ID, Fix Len = 04 bytes)
            payload += "6304";
            payload += crc16(payload);

            return payload;
        }

        function copyPix() {
            const key = document.getElementById("pixKey").textContent;
            navigator.clipboard.writeText(key).then(() => {
                const btn = document.querySelector(".copy-pix-btn");
                const old = btn.textContent;
                btn.textContent = "Copiado!";
                btn.style.background = "#d1fae5";
                btn.style.color = "#065f46";
                setTimeout(() => {
                    btn.textContent = old;
                    btn.style.background = "#e2e8f0";
                    btn.style.color = "#475569";
                }, 2000);
            });
        }

        function copyQrUrl() {
            const val = document.getElementById("pixQrUrlInput").value;
            navigator.clipboard.writeText(val).then(() => {
                const btn = document.getElementById("btnCopyQrUrl");
                const old = btn.textContent;
                btn.textContent = "Copiado!";
                btn.style.background = "#d1fae5";
                btn.style.color = "#065f46";
                setTimeout(() => {
                    btn.textContent = old;
                    btn.style.background = "#e2e8f0";
                    btn.style.color = "#475569";
                }, 2000);
            });
        }

        function payPoints() {
            const confirmationCheckbox = document.getElementById("confirmPaymentCheck");
            if (!confirmationCheckbox?.checked) {
                alert("Confirme que a operação foi realmente concluída antes de finalizar.");
                return;
            }
            document.getElementById("confirmPaymentHidden").value = "yes";
            if (
                confirm(
                    "Deseja converter este valor em pontos e creditar ao parceiro?",
                )
            ) {
                document.getElementById("pixAction").value = "pay_points";
                document.getElementById("formPayNow").submit();
            }
        }

        const pixModal = document.getElementById("pixModal");
        const confirmPaymentCheck = document.getElementById("confirmPaymentCheck");
        const confirmPaymentHidden = document.getElementById("confirmPaymentHidden");
        pixModal.addEventListener("click", (e) => {
            if (e.target === pixModal) pixModal.close();
        });

        confirmPaymentCheck?.addEventListener("change", () => {
            if (confirmPaymentHidden) {
                confirmPaymentHidden.value = confirmPaymentCheck.checked ? "yes" : "no";
            }
        });

        document.getElementById("formPayNow")?.addEventListener("submit", (e) => {
            const checkbox = document.getElementById("confirmPaymentCheck");
            if (!checkbox?.checked) {
                e.preventDefault();
                alert("Confirme que o pagamento foi realmente efetuado antes de concluir.");
            }
        });
    </script>

