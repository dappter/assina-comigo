---
// Este componente cria um efeito interativo 3D usando a imagem do Roteador Ligeira Oficial!
---

<div class="relative w-full max-w-4xl mx-auto py-24 flex flex-col items-center justify-center -mt-8 mb-16 px-4">
  <div class="text-center mb-10 z-10">
    <h2 class="text-4xl md:text-5xl font-display font-extrabold text-slate-900 dark:text-white tracking-tight mb-4 drop-shadow-sm">
      A verdadeira força da Fibra
    </h2>
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm font-semibold text-primary mb-2">
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
      Roteador Oficial Ligeira
    </div>
    <p class="text-slate-500 dark:text-slate-400 text-lg md:text-xl font-medium mt-3">
      Arraste <span class="hidden md:inline">o mouse</span> para interagir com nosso equipamento de ponta.
    </p>
  </div>

  <!-- Nosso container de drag que não usa uma tela inteira e 300vh -->
  <div 
    id="router-interactive-container"
    class="relative w-full max-w-[320px] md:max-w-md aspect-[3/4] select-none cursor-grab active:cursor-grabbing rounded-3xl"
    style="perspective: 1200px;"
  >
    <!-- Brilho ao redor -->
    <div class="absolute inset-0 bg-primary/20 blur-3xl rounded-full scale-75 opacity-60 animate-pulse delay-75"></div>
    <div class="absolute inset-0 bg-yellow-400/20 blur-3xl rounded-full scale-50 opacity-40 translate-y-12 animate-pulse"></div>

    <img 
      id="router-image"
      src="/roteador-oficial.png" 
      alt="Roteador Oficial Ligeira" 
      class="absolute inset-0 w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-transform duration-[50ms] origin-center pointer-events-none z-10"
      draggable="false"
    />
  </div>
</div>

<script is:inline>
  const container = document.getElementById('router-interactive-container');
  const img = document.getElementById('router-image');
  
  let isDragging = false;
  let startX = 0;
  let startY = 0;
  // Estado real da rotação
  let currentRotX = 0;
  let currentRotY = 0;

  function updateTransform(x, y) {
    if(!img) return;
    img.style.transform = `rotateX(${x}deg) rotateY(${y}deg) scale(1.05)`;
  }

  container.addEventListener('pointerdown', (e) => {
    isDragging = true;
    startX = e.clientX;
    startY = e.clientY;
    container.setPointerCapture(e.pointerId);
  });

  container.addEventListener('pointermove', (e) => {
    if (!isDragging) {
      // Pequeno efeito 3D quando apenas passar o mouse por cima
      const rect = container.getBoundingClientRect();
      const x = e.clientX - rect.left - (rect.width / 2);
      const y = e.clientY - rect.top - (rect.height / 2);
      const hoverRotY = (x / rect.width) * 30; // máx rotação
      const hoverRotX = -(y / rect.height) * 30;
      updateTransform(hoverRotX, hoverRotY);
      return;
    }
    
    // Efeito de arraste agressivo!
    const deltaX = e.clientX - startX;
    const deltaY = e.clientY - startY;
    
    currentRotY += deltaX * 0.7; // Sensibilidade Y
    currentRotX -= deltaY * 0.7; // Sensibilidade X
    
    // Evita capotar de cabeça pra baixo
    currentRotX = Math.max(-45, Math.min(45, currentRotX));
    
    // Atualiza base para a próxima frame do arraste
    startX = e.clientX;
    startY = e.clientY;
    
    updateTransform(currentRotX, currentRotY);
  });

  // Reseta ao soltar
  const resetTransform = () => {
    isDragging = false;
    currentRotX = 0;
    currentRotY = 0;
    if(img) {
      img.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
      img.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
      setTimeout(() => img.style.transition = 'transform 50ms', 400);
    }
  };

  container.addEventListener('pointerup', resetTransform);
  container.addEventListener('pointercancel', resetTransform);
  container.addEventListener('pointerleave', () => {
    if(!isDragging) resetTransform();
  });
</script>
