---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"svg"> {
  icon: any; // O componente importado da biblioteca lucide-astro
  size?: number | string;
  color?: string;
  strokeWidth?: number | string;
}

const {
  icon: IconComponent,
  size = 24,
  color = "currentColor",
  strokeWidth = 2, // Espessura padrão de 2px (Design 'SaaS Premium')
  class: className,
  ...rest
} = Astro.props;
---

<IconComponent
  size={size}
  color={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  {...rest}
/>
