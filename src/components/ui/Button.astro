---
import type { HTMLAttributes } from "astro/types";
import Icon from "./Icon.astro";

interface Props extends HTMLAttributes<"button"> {
  variant?:
    | "primary"
    | "secondary"
    | "outline"
    | "ghost"
    | "whatsapp"
    | "danger";
  size?: "sm" | "md" | "lg";
  iconLeft?: any;
  iconRight?: any;
  fullWidth?: boolean;
}

const {
  variant = "primary",
  size = "md",
  type = "button",
  class: className = "",
  iconLeft,
  iconRight,
  disabled = false,
  fullWidth = false,
  ...rest
} = Astro.props;

const finalClasses = [
  "btn",
  `btn-${variant}`,
  `btn-${size}`,
  fullWidth ? "btn-full" : "",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<button type={type} class={finalClasses} disabled={disabled} {...rest}>
  {iconLeft && <Icon icon={iconLeft} size={size === "sm" ? 16 : 18} />}
  <slot />
  {iconRight && <Icon icon={iconRight} size={size === "sm" ? 16 : 18} />}
</button>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 1.5px solid transparent;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: "Inter", sans-serif;
    font-weight: 700;
    transition: var(--transition-normal);
    white-space: nowrap;
    text-decoration: none;
    line-height: 1;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn:active {
    transform: scale(0.98);
  }

  /* Sizes */
  .btn-sm {
    padding: 0.625rem 1.25rem;
    font-size: 0.8125rem;
    border-radius: var(--radius-sm);
  }
  .btn-md {
    padding: 0.875rem 1.75rem;
    font-size: 0.875rem;
  }
  .btn-lg {
    padding: 1.125rem 2.25rem;
    font-size: 1rem;
    border-radius: var(--radius-lg);
  }

  .btn-full {
    width: 100%;
  }

  /* Variants */
  .btn-primary {
    background: var(--color-brand-primary);
    color: #111827;
    box-shadow: 0 4px 12px rgba(255, 185, 24, 0.3);
  }
  .btn-primary:hover {
    background: var(--color-brand-primary-dark);
    box-shadow: 0 6px 16px rgba(255, 185, 24, 0.4);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: var(--color-brand-secondary);
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(0, 98, 255, 0.2);
  }
  .btn-secondary:hover {
    background: var(--color-brand-secondary-dark);
    box-shadow: 0 6px 16px rgba(0, 98, 255, 0.3);
    transform: translateY(-1px);
  }

  .btn-outline {
    background: transparent;
    border-color: var(--color-brand-secondary);
    color: var(--color-brand-secondary);
  }
  .btn-outline:hover {
    background: var(--color-brand-secondary-light);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-body);
  }
  .btn-ghost:hover {
    background: var(--color-bg-alt);
    color: var(--color-heading);
  }

  .btn-whatsapp {
    background: #25d366;
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.2);
  }
  .btn-whatsapp:hover {
    background: #1eb957;
    box-shadow: 0 6px 16px rgba(37, 211, 102, 0.3);
    transform: translateY(-1px);
  }

  .btn-danger {
    background: #fee2e2;
    color: #991b1b;
    border-color: #f87171;
  }
  .btn-danger:hover {
    background: #ff2d55;
    color: #fff;
    border-color: #ff2d55;
  }
</style>
