---
import "../styles/global.css";
import raioLogo from "../assets/icons/RAIO.png";
import faviconIco from "../assets/icons/favicon.ico";
import favicon16 from "../assets/icons/favicon-16x16.png";
import favicon32 from "../assets/icons/favicon-32x32.png";
import appleTouchIcon from "../assets/icons/apple-touch-icon.png";
import android192 from "../assets/icons/android-chrome-192x192.png";
import android512 from "../assets/icons/android-chrome-512x512.png";

interface Props {
    title: string;
    description?: string;
    userAvatar?: string;
    userName?: string;
}

const {
    title,
    description = "Painel Administrador",
    userAvatar = "AD",
    userName = "Administrador",
} = Astro.props;

const pathname = Astro.url.pathname;
const isActive = (path: string) =>
    pathname === path || pathname.startsWith(path + "/");
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/x-icon" href={faviconIco.src} />
        <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} />
        <link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
        <link rel="icon" type="image/png" sizes="16x16" href={favicon16.src} />
        <link rel="icon" type="image/png" sizes="192x192" href={android192.src} />
        <link rel="icon" type="image/png" sizes="512x512" href={android512.src} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <meta name="generator" content={Astro.generator} />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@600;700;800;900&display=swap"
            rel="stylesheet"
        />
        <title>{title} | Admin Assina Comigo</title>
    </head>
    <body class="dashboard-body">
        <div class="dashboard-shell">
            <!-- Sidebar -->
            <aside class="sidebar" id="sidebar" aria-label="Menu de navegação">
                <!-- Brand Area -->
                <div class="sidebar-brand">
                    <div
                        class="sidebar-logo"
                        style="background: var(--linear-brand); background: linear-gradient(135deg, #6028FF, #4B1AC8); color: white;"
                    >
                        <img alt="Ligeira" src={raioLogo.src} />
                    </div>
                    <div class="sidebar-brand-info">
                        <span class="sidebar-brand-name">Assina Comigo</span>
                        <span class="sidebar-brand-text">Admin Center</span>
                    </div>
                </div>

                <!-- Navigation -->
                <nav class="sidebar-nav" aria-label="Navegação principal">
                    <div class="nav-section">Principal</div>

                    <a
                        href="/admin/dashboard"
                        class={`nav-item ${isActive("/admin/dashboard") && pathname === "/admin/dashboard" ? "active" : ""}`}
                    >
                        <svg
                            class="nav-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        Visão Geral
                    </a>

                    <a
                        href="/admin/indicacoes"
                        class={`nav-item ${isActive("/admin/indicacoes") ? "active" : ""}`}
                    >
                        <svg
                            class="nav-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <polygon
                                points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"
                            ></polygon>
                        </svg>
                        Indicações (Funil)
                    </a>

                    <a
                        href="/admin/pagamentos"
                        class={`nav-item ${isActive("/admin/pagamentos") ? "active" : ""}`}
                    >
                        <svg
                            class="nav-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path
                                d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                            ></path>
                        </svg>
                        Pagamentos
                    </a>

                    <div class="nav-section" style="margin-top: 1.5rem">
                        Equipe de Vendas
                    </div>

                    <a
                        href="/vendedor/dashboard"
                        class={`nav-item ${isActive("/vendedor/dashboard") ? "active" : ""}`}
                    >
                        <svg
                            class="nav-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                            ></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        Painel de Vendas
                    </a>

                    <div class="nav-section" style="margin-top: 1.5rem">
                        Comunidade
                    </div>

                    <a
                        href="/admin/parceiros"
                        class={`nav-item ${isActive("/admin/parceiros") ? "active" : ""}`}
                    >
                        <svg
                            class="nav-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                            ></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        Parceiros
                    </a>

                    <a
                        href="/admin/grupos"
                        class={`nav-item ${isActive("/admin/grupos") ? "active" : ""}`}
                    >
                        <svg
                            class="nav-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <rect
                                x="3"
                                y="3"
                                width="18"
                                height="18"
                                rx="2"
                                ry="2"></rect>
                            <line x1="3" y1="9" x2="21" y2="9"></line>
                            <line x1="9" y1="21" x2="9" y2="9"></line>
                        </svg>
                        Grupos & Níveis
                    </a>

                    <div class="nav-section" style="margin-top: 1.5rem">
                        Sistema
                    </div>

                    <a
                        href="/admin/configuracoes"
                        class={`nav-item ${isActive("/admin/configuracoes") ? "active" : ""}`}
                    >
                        <svg
                            class="nav-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="3"></circle>
                            <path
                                d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33 1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82 1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
                            ></path>
                        </svg>
                        Configurações
                    </a>
                </nav>

                <!-- Sidebar Footer -->
                <div class="sidebar-user">
                    <div class="user-avatar">{userAvatar}</div>
                    <div class="user-info">
                        <strong>{userName}</strong>
                        <span style="color: var(--color-brand-primary-light);"
                            >Administrador</span
                        >
                    </div>
                    <button
                        class="logout-btn"
                        id="logoutBtn"
                        title="Sair"
                        aria-label="Sair"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
                            ></path>
                            <polyline points="16 17 21 12 16 7"></polyline>
                            <line x1="21" y1="12" x2="9" y2="12"></line>
                        </svg>
                    </button>
                </div>
            </aside>

            <!-- Main Panel -->
            <div class="content-panel">
                <header class="topbar">
                    <button
                        class="menu-toggle"
                        id="menuToggle"
                        aria-label="Abrir menu"
                        aria-expanded="false"
                        aria-controls="sidebar"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            style="width:24px;height:24px"
                        >
                            <line x1="3" y1="12" x2="21" y2="12"></line>
                            <line x1="3" y1="6" x2="21" y2="6"></line>
                            <line x1="3" y1="18" x2="21" y2="18"></line>
                        </svg>
                    </button>

                    <div class="topbar-mobile-title">
                        <span class="sidebar-brand-text">Admin</span>
                    </div>

                    <div class="topbar-search">
                        <!-- Search seletivo do Admin -->
                    </div>

                    <div class="topbar-actions">
                        <div
                            class="topbar-user-mini"
                            aria-label="Modo Admin Ativo"
                        >
                            <span
                                class="topbar-user-name"
                                style="color: var(--color-brand-primary); font-weight: 700;"
                                >Modo Admin</span
                            >
                        </div>
                    </div>
                </header>

                <main class="main-content" id="main-content">
                    <div class="content-inner">
                        <slot />
                    </div>
                </main>
            </div>
        </div>

        <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true">
        </div>

        <!-- Dialog Global de Confirmação de Logout do Admin -->
        <dialog
            class="confirm-dialog"
            id="globalLogoutDialog"
            aria-modal="true"
            aria-labelledby="globalDialogTitle"
        >
            <div class="dialog-content">
                <div class="dialog-icon">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="32"
                        height="32"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
                        ></path><polyline points="16 17 21 12 16 7"
                        ></polyline><line x1="21" y1="12" x2="9" y2="12"
                        ></line></svg
                    >
                </div>
                <h2 id="globalDialogTitle">Sair da conta?</h2>
                <p>
                    Você precisará fazer login novamente para acessar o
                    painel.
                </p>
                <div class="dialog-actions">
                    <button class="btn-cancel" id="cancelGlobalLogout" autofocus
                        >Cancelar</button
                    >
                    <button class="btn-confirm-logout" id="confirmGlobalLogout"
                        >Sim, sair</button
                    >
                </div>
            </div>
        </dialog>

        <!-- Bottom Nav Mobile -->
        <nav class="bottom-nav" aria-label="Navegação mobile">
            <a href="/admin/dashboard" class={`bnav-item ${pathname === "/admin/dashboard" ? "active" : ""}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"></rect>
                    <rect x="14" y="3" width="7" height="7"></rect>
                    <rect x="14" y="14" width="7" height="7"></rect>
                    <rect x="3" y="14" width="7" height="7"></rect>
                </svg>
                <span>Início</span>
            </a>
            <a href="/admin/indicacoes" class={`bnav-item ${isActive("/admin/indicacoes") ? "active" : ""}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                </svg>
                <span>Funil</span>
            </a>
            <a href="/admin/pagamentos" class={`bnav-item ${isActive("/admin/pagamentos") ? "active" : ""}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"></line>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
                <span>Caixa</span>
            </a>
            <a href="/admin/parceiros" class={`bnav-item ${isActive("/admin/parceiros") ? "active" : ""}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                <span>Parceiros</span>
            </a>
        </nav>

        <script>
            const menuToggle = document.getElementById("menuToggle");
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("sidebarOverlay");

            function openSidebar() {
                sidebar?.classList.add("mobile-open");
                overlay?.classList.add("visible");
                menuToggle?.setAttribute("aria-expanded", "true");
                document.body.style.overflow = "hidden";
            }

            function closeSidebar() {
                sidebar?.classList.remove("mobile-open");
                overlay?.classList.remove("visible");
                menuToggle?.setAttribute("aria-expanded", "false");
                document.body.style.overflow = "";
            }

            menuToggle?.addEventListener("click", openSidebar);
            overlay?.addEventListener("click", closeSidebar);

            sidebar?.querySelectorAll(".nav-item").forEach((link) => {
                link.addEventListener("click", () => {
                    if (window.innerWidth < 1024) closeSidebar();
                });
            });

            const logoutBtn = document.getElementById("logoutBtn");
            const globalLogoutDialog = document.getElementById(
                "globalLogoutDialog",
            ) as HTMLDialogElement | null;
            const cancelGlobalLogout =
                document.getElementById("cancelGlobalLogout");
            const confirmGlobalLogout = document.getElementById(
                "confirmGlobalLogout",
            );

            logoutBtn?.addEventListener("click", () => {
                globalLogoutDialog?.showModal();
            });

            cancelGlobalLogout?.addEventListener("click", () => {
                globalLogoutDialog?.close();
            });

            confirmGlobalLogout?.addEventListener("click", async () => {
                if (confirmGlobalLogout) {
                    confirmGlobalLogout.textContent = "Saindo...";
                    (confirmGlobalLogout as HTMLButtonElement).disabled = true;
                }
                try {
                    await fetch("/api/auth/logout", { method: "POST" });
                    window.location.href = "/admin/login";
                } catch {
                    window.location.href = "/admin/login";
                }
            });

            globalLogoutDialog?.addEventListener("click", (e) => {
                if (e.target === globalLogoutDialog) globalLogoutDialog.close();
            });
        </script>
    </body>
</html>

<style>
    .dashboard-body {
        background-color: var(--color-bg-base);
        min-height: 100vh;
        overflow-x: hidden;
    }
    .dashboard-shell {
        display: flex;
        min-height: 100vh;
    }
    
    /* Dialog de Logout Global do Admin */
    .confirm-dialog {
        border: none;
        border-radius: var(--radius-2xl);
        padding: 0;
        max-width: 400px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    }
    .confirm-dialog::backdrop {
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
    }
    .dialog-content {
        padding: 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
    }
    .dialog-icon {
        width: 64px;
        height: 64px;
        background: #fee2e2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #991b1b;
    }
    .dialog-content h2 {
        font-size: 1.25rem;
        margin: 0;
        color: var(--color-heading);
    }
    .dialog-content p {
        font-size: 0.9rem;
        color: var(--color-subtle);
    }
    .dialog-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.75rem;
        width: 100%;
    }
    .btn-cancel {
        flex: 1;
        padding: 0.875rem;
        border-radius: var(--radius-md);
        background: var(--color-bg-alt);
        color: var(--color-heading);
        font-size: 0.875rem;
        font-weight: 700;
        font-family: "Inter", sans-serif;
        border: 1px solid var(--color-border);
        transition: var(--transition-fast);
        cursor: pointer;
    }
    .btn-cancel:hover {
        background: var(--color-border);
    }
    .btn-confirm-logout {
        flex: 1;
        padding: 0.875rem;
        border-radius: var(--radius-md);
        background: #ff2d55;
        color: #fff;
        font-size: 0.875rem;
        font-weight: 700;
        font-family: "Inter", sans-serif;
        border: none;
        transition: var(--transition-fast);
        cursor: pointer;
    }
    .btn-confirm-logout:hover {
        background: #e0001e;
    }
    .btn-confirm-logout:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
    .sidebar {
        width: 260px;
        background: linear-gradient(180deg, #140030 0%, #1a0044 100%);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        transition: var(--transition-normal);
        position: sticky;
        top: 0;
        height: 100vh;
        z-index: 50;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .sidebar::-webkit-scrollbar {
        display: none;
    }
    .sidebar-brand {
        padding: 1.5rem 1.75rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        flex-shrink: 0;
    }
    .sidebar-logo {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
        overflow: hidden;
    }
    .sidebar-logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }
    .sidebar-brand-info {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }
    .sidebar-brand-name {
        font-family: "Outfit", sans-serif;
        font-weight: 900;
        font-size: 1.1rem;
        letter-spacing: -0.02em;
        color: #fff;
        display: block;
    }
    .sidebar-brand-text {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 0.7rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        white-space: nowrap;
    }
    .sidebar-nav {
        flex: 1;
        padding: 1.25rem 0.875rem;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .sidebar-nav::-webkit-scrollbar {
        display: none;
    }
    .nav-section {
        padding: 0 0.875rem 0.625rem;
        font-size: 0.68rem;
        font-weight: 800;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.12em;
    }
    .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 0.875rem;
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-weight: 500;
        color: #94a3b8;
        text-decoration: none;
        transition: var(--transition-fast);
        margin-bottom: 0.25rem;
        min-height: 44px;
        position: relative;
    }
    .nav-item:hover {
        background: rgba(255, 191, 26, 0.12);
        color: #ffffff;
        box-shadow: inset 0 0 0 1px rgba(255, 191, 26, 0.12);
    }
    .nav-item.active {
        background: linear-gradient(135deg, rgba(255, 191, 26, 0.16), rgba(96, 40, 255, 0.16));
        color: #ffffff;
        font-weight: 600;
    }
    .nav-item.active::before {
        content: "";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 3px;
        height: 60%;
        background: var(--color-brand-primary);
        border-radius: 0 3px 3px 0;
    }
    .nav-icon {
        width: 1.1rem;
        height: 1.1rem;
        flex-shrink: 0;
    }
    .sidebar-user {
        padding: 1.125rem 1.25rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-shrink: 0;
    }
    .user-avatar {
        width: 36px;
        height: 36px;
        background: rgba(96, 40, 255, 0.25);
        color: #c4adff;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 0.72rem;
        font-weight: 800;
    }
    .user-info {
        flex: 1;
        min-width: 0;
    }
    .user-info strong {
        display: block;
        font-size: 0.8rem;
        color: #f1f5f9;
        white-space: nowrap;
        overflow: hidden;
