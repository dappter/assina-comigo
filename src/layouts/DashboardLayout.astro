---
import "../styles/global.css";
import raioLogo from "../assets/icons/RAIO.png";
import faviconIco from "../assets/icons/favicon.ico";
import favicon16 from "../assets/icons/favicon-16x16.png";
import favicon32 from "../assets/icons/favicon-32x32.png";
import appleTouchIcon from "../assets/icons/apple-touch-icon.png";
import android192 from "../assets/icons/android-chrome-192x192.png";
import android512 from "../assets/icons/android-chrome-512x512.png";
import Onboarding from "../components/Onboarding.astro";
import { supabaseAdmin } from "../lib/supabaseAdmin";

interface Props {
  title: string;
  description?: string;
  userAvatar?: string;
  userName?: string;
}

const {
  title,
  description = "Painel Assina Comigo",
  userAvatar = "UA",
  userName = "Usuário",
} = Astro.props;

const pathname = Astro.url.pathname;
const onboardingUserId = Astro.locals.profileId || "";
const tenantId = Astro.locals.tenantId || "";
const profileId = Astro.locals.profileId || "";
const isActive = (path: string) =>
  pathname === path || pathname.startsWith(path + "/");

let latestNotificationAt = "";
let needsPix = false;
if (tenantId && profileId) {
  const [{ data: latestLead }, { data: latestComissao }, { data: profile }] = await Promise.all([
    supabaseAdmin
      .from("leads")
      .select("created_at")
      .eq("tenant_id", tenantId)
      .eq("parceiro_id", profileId)
      .order("created_at", { ascending: false })
      .limit(1)
      .maybeSingle(),
    supabaseAdmin
      .from("comissoes")
      .select("created_at")
      .eq("tenant_id", tenantId)
      .eq("parceiro_id", profileId)
      .order("created_at", { ascending: false })
      .limit(1)
      .maybeSingle(),
    supabaseAdmin
      .from("profiles")
      .select("chave_pix")
      .eq("id", profileId)
      .maybeSingle()
  ]);

  const leadTs = latestLead?.created_at ? new Date(latestLead.created_at).getTime() : 0;
  const comissaoTs = latestComissao?.created_at
    ? new Date(latestComissao.created_at).getTime()
    : 0;
  const maxTs = Math.max(leadTs, comissaoTs);
  latestNotificationAt = maxTs > 0 ? new Date(maxTs).toISOString() : "";
  needsPix = !profile?.chave_pix;
}
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={faviconIco.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16.src} />
    <link rel="icon" type="image/png" sizes="192x192" href={android192.src} />
    <link rel="icon" type="image/png" sizes="512x512" href={android512.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Assina Comigo</title>
  </head>
  <body class="dashboard-body flex flex-col items-center">
    {needsPix && (
        <a href="/parceiro/completar-cadastro" class="w-full bg-red-600 text-white font-bold text-center py-2 z-[9999] opacity-95 block hover:bg-red-700 hover:opacity-100 transition font-headline shadow-md text-sm md:text-base sticky top-0">
            ⚠️ Atenção: Sua chave PIX não está configurada! Clique aqui para adicionar e poder sacar seus ganhos.
        </a>
    )}
    <div class="dashboard-shell w-full flex-1 relative">
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar" aria-label="Menu de navegação">
        <!-- Brand Area -->
        <div class="sidebar-brand">
          <div class="sidebar-logo">
            <img alt="Ligeira" src={raioLogo.src} />
          </div>
          <span class="sidebar-brand-text">Assina Comigo</span>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav" aria-label="Navegação principal">
          <div class="nav-section">Principal</div>

          <a
            href="/parceiro/dashboard"
            class={`nav-item ${isActive("/parceiro/dashboard") && pathname === "/parceiro/dashboard" ? "active" : ""}`}
            aria-current={pathname === "/parceiro/dashboard"
              ? "page"
              : undefined}
          >
            <svg
              class="nav-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            Visão Geral
          </a>

          <a
            href="/parceiro/indicados"
            class={`nav-item ${isActive("/parceiro/indicados") ? "active" : ""}`}
            aria-current={isActive("/parceiro/indicados") ? "page" : undefined}
          >
            <svg
              class="nav-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            Meus Indicados
          </a>

          <a
            href="/parceiro/ganhos"
            class={`nav-item ${isActive("/parceiro/ganhos") ? "active" : ""}`}
            aria-current={isActive("/parceiro/ganhos") ? "page" : undefined}
          >
            <svg
              class="nav-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="12" y1="1" x2="12" y2="23"></line>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
              ></path>
            </svg>
            Ganhos
          </a>

          <a
            href="/parceiro/pontos"
            class={`nav-item ${isActive("/parceiro/pontos") ? "active" : ""}`}
            aria-current={isActive("/parceiro/pontos") ? "page" : undefined}
          >
            <svg
              class="nav-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polygon
                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
              ></polygon>
            </svg>
            Pontos
          </a>

          <div class="nav-section" style="margin-top: 1.5rem">Conta</div>

          <a
            href="/parceiro/perfil"
            class={`nav-item ${isActive("/parceiro/perfil") ? "active" : ""}`}
            aria-current={isActive("/parceiro/perfil") ? "page" : undefined}
          >
            <svg
              class="nav-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            Meu Perfil
          </a>

          <a
            href="/parceiro/configuracoes"
            class={`nav-item ${isActive("/parceiro/configuracoes") ? "active" : ""}`}
            aria-current={isActive("/parceiro/configuracoes")
              ? "page"
              : undefined}
          >
            <svg
              class="nav-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="3"></circle>
              <path
                d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33 1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82 1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
              ></path>
            </svg>
            Configurações
          </a>
        </nav>

        <!-- Sidebar Footer -->
        <div class="sidebar-user">
          <a
            href="/parceiro/perfil"
            class="user-avatar-link"
            aria-label="Ver perfil"
          >
            <div class="user-avatar">{userAvatar}</div>
          </a>
          <div class="user-info">
            <strong>{userName}</strong>
            <span>Parceiro</span>
          </div>
          <button
            class="logout-btn"
            id="logoutBtn"
            title="Sair da conta"
            aria-label="Sair da conta"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
          </button>
        </div>
      </aside>

      <!-- Main Panel -->
      <div class="content-panel">
        <!-- Topbar -->
        <header class="topbar">
          <button
            class="menu-toggle"
            id="menuToggle"
            aria-label="Abrir menu"
            aria-expanded="false"
            aria-controls="sidebar"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="width:24px;height:24px"
            >
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>

          <!-- Título mobile -->
          <div class="topbar-mobile-title">
            <span class="sidebar-brand-text">Assina Comigo</span>
          </div>

          <div class="topbar-search">
            <div class="search-wrap">
              <svg
                class="search-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <input
                type="text"
                placeholder="Pesquisar indicação..."
                class="search-input"
                aria-label="Pesquisar indicação"
              />
            </div>
          </div>

          <div class="topbar-actions">
            <!-- Notificações -->
            <a
              href="/parceiro/notificacoes"
              id="notificationBtn"
              class="top-btn"
              aria-label="Ver notificações"
              title="Notificações"
              data-latest-notification-at={latestNotificationAt}
              data-profile-id={profileId}
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="width:20px;height:20px"
              >
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
              <span class="notification-dot hidden" id="notificationDot"></span>
            </a>

            <div class="topbar-sep" aria-hidden="true"></div>

            <!-- Avatar / Perfil -->
            <a
              href="/parceiro/perfil"
              class="topbar-user-mini"
              aria-label="Ir para meu perfil"
            >
              <span class="topbar-user-name">{userName}</span>
              <div class="mini-avatar" aria-hidden="true">{userAvatar}</div>
            </a>
          </div>
        </header>

        <!-- Main Content Scroll Area -->
        <main class="main-content" id="main-content">
          <div class="content-inner">
            <slot />
          </div>
        </main>
      </div>
    </div>

    {onboardingUserId && <Onboarding userId={onboardingUserId} />}

    <!-- Mobile Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>

    <!-- Dialog Global de Confirmação de Logout -->
    <dialog
      class="confirm-dialog"
      id="globalLogoutDialog"
      aria-modal="true"
      aria-labelledby="globalDialogTitle"
    >
      <div class="dialog-content">
        <div class="dialog-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
            ></path><polyline points="16 17 21 12 16 7"
            ></polyline><line x1="21" y1="12" x2="9" y2="12"
            ></line></svg
          >
        </div>
        <h2 id="globalDialogTitle">Sair da conta?</h2>
        <p>
          Você precisará fazer login novamente para acessar o painel.
        </p>
        <div class="dialog-actions">
          <button class="btn-cancel" id="cancelGlobalLogout" autofocus
            >Cancelar</button
          >
          <button class="btn-confirm-logout" id="confirmGlobalLogout"
            >Sim, sair</button
          >
        </div>
      </div>
    </dialog>

    <!-- Bottom Nav Mobile -->
    <nav class="bottom-nav" aria-label="Navegação mobile">
      <a
        href="/parceiro/dashboard"
        class={`bnav-item ${pathname === "/parceiro/dashboard" ? "active" : ""}`}
        aria-label="Visão Geral"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="3" width="7" height="7"></rect>
          <rect x="14" y="3" width="7" height="7"></rect>
          <rect x="14" y="14" width="7" height="7"></rect>
          <rect x="3" y="14" width="7" height="7"></rect>
        </svg>
        <span>Início</span>
      </a>
      <a
        href="/parceiro/indicados"
        class={`bnav-item ${isActive("/parceiro/indicados") ? "active" : ""}`}
        aria-label="Meus Indicados"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
        <span>Indicados</span>
      </a>
      <a
        href="/parceiro/ganhos"
        class={`bnav-item ${isActive("/parceiro/ganhos") ? "active" : ""}`}
        aria-label="Ganhos"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="12" y1="1" x2="12" y2="23"></line>
          <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
        </svg>
        <span>Ganhos</span>
      </a>
      <a
        href="/parceiro/perfil"
        class={`bnav-item ${isActive("/parceiro/perfil") ? "active" : ""}`}
        aria-label="Meu Perfil"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        <span>Perfil</span>
      </a>
    </nav>

    <script>
      // Menu toggle
      const menuToggle = document.getElementById("menuToggle");
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebarOverlay");

      function openSidebar() {
        sidebar?.classList.add("mobile-open");
        overlay?.classList.add("visible");
        menuToggle?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
      }

      function closeSidebar() {
        sidebar?.classList.remove("mobile-open");
        overlay?.classList.remove("visible");
        menuToggle?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      }

      menuToggle?.addEventListener("click", openSidebar);
      overlay?.addEventListener("click", closeSidebar);

      // Fechar sidebar ao clicar em um link de navegação no mobile
      sidebar?.querySelectorAll(".nav-item").forEach((link) => {
        link.addEventListener("click", () => {
          if (window.innerWidth < 1024) closeSidebar();
        });
      });

      // Logout
      const logoutBtn = document.getElementById("logoutBtn");
      const globalLogoutDialog = document.getElementById("globalLogoutDialog") as HTMLDialogElement | null;
      const cancelGlobalLogout = document.getElementById("cancelGlobalLogout");
      const confirmGlobalLogout = document.getElementById("confirmGlobalLogout");

      logoutBtn?.addEventListener("click", () => {
        globalLogoutDialog?.showModal();
      });

      cancelGlobalLogout?.addEventListener("click", () => {
        globalLogoutDialog?.close();
      });

      confirmGlobalLogout?.addEventListener("click", async () => {
        if (confirmGlobalLogout) {
          confirmGlobalLogout.textContent = "Saindo...";
          (confirmGlobalLogout as HTMLButtonElement).disabled = true;
        }
        try {
          await fetch("/api/auth/logout", { method: "POST" });
          window.location.href = "/parceiro/login";
        } catch {
          window.location.href = "/parceiro/login";
        }
      });

      globalLogoutDialog?.addEventListener("click", (e) => {
        if (e.target === globalLogoutDialog) globalLogoutDialog.close();
      });

      // Notificações: exibe bolinha vermelha apenas quando há item novo.
      const notificationBtn = document.getElementById("notificationBtn");
      const notificationDot = document.getElementById("notificationDot");
      const latestNotificationAt = notificationBtn?.getAttribute("data-latest-notification-at") || "";
      const currentProfileId = notificationBtn?.getAttribute("data-profile-id") || "";
      const seenKey = currentProfileId
        ? `assina:notifications:last_seen:${currentProfileId}`
        : "";

      function updateNotificationDot() {
        if (!notificationDot || !seenKey || !latestNotificationAt) {
          notificationDot?.classList.add("hidden");
          return;
        }

        if (window.location.pathname.startsWith("/parceiro/notificacoes")) {
          localStorage.setItem(seenKey, latestNotificationAt);
          notificationDot.classList.add("hidden");
          return;
        }

        const lastSeen = localStorage.getItem(seenKey);
        const hasNew = !lastSeen || new Date(latestNotificationAt).getTime() > new Date(lastSeen).getTime();
        notificationDot.classList.toggle("hidden", !hasNew);
      }

      updateNotificationDot();
    </script>
  </body>
</html>

<style>
  .dashboard-body {
    background-color: var(--color-bg-base);
    min-height: 100vh;
    overflow-x: hidden;
  }

  .dashboard-shell {
    display: flex;
    min-height: 100vh;
  }

  /* Dialog de Logout Global */
  .confirm-dialog {
    border: none;
    border-radius: var(--radius-2xl);
    padding: 0;
    max-width: 400px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }
  .confirm-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  .dialog-content {
    padding: 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .dialog-icon {
    width: 64px;
    height: 64px;
    background: #fee2e2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #991b1b;
  }
  .dialog-content h2 {
    font-size: 1.25rem;
    margin: 0;
    color: var(--color-heading);
  }
  .dialog-content p {
    font-size: 0.9rem;
    color: var(--color-subtle);
  }
  .dialog-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.75rem;
    width: 100%;
  }
  .btn-cancel {
    flex: 1;
    padding: 0.875rem;
    border-radius: var(--radius-md);
    background: var(--color-bg-alt);
    color: var(--color-heading);
    font-size: 0.875rem;
    font-weight: 700;
    font-family: "Inter", sans-serif;
    border: 1px solid var(--color-border);
    transition: var(--transition-fast);
    cursor: pointer;
  }
  .btn-cancel:hover {
    background: var(--color-border);
  }
  .btn-confirm-logout {
    flex: 1;
    padding: 0.875rem;
    border-radius: var(--radius-md);
    background: #ff2d55;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 700;
    font-family: "Inter", sans-serif;
    border: none;
    transition: var(--transition-fast);
    cursor: pointer;
  }
  .btn-confirm-logout:hover {
    background: #e0001e;
  }
  .btn-confirm-logout:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* ===================== SIDEBAR ===================== */
  .sidebar {
    width: 260px;
    background: linear-gradient(180deg, #140030 0%, #1a0044 100%);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    transition: var(--transition-normal);
